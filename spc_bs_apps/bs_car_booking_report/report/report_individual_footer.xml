                    <span>(ลงชื่อ)</span>&#160;&#160;
                    <span>.........................................</span>&#160;&#160;
                    <span>พนักงานขาย</span>
                </td>
            </tr>
            <tr style="font-weight:bold;">
                <td style="text-align:center;">
                    <span>( นายเดชากร ทัศนกูล )</span>
                </td>
                <td style="text-align:center;">
                    <span>( นางสาวดิถา กาญจนาภา )</span>
                </td>
            </tr>
        </table>

