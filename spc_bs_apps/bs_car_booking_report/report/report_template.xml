<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Layout wrapper for each booking contract document.
        Mirrors bs_from_tax_invoice_th.request_layout pattern:
        wraps content in the article div with o_company_N_layout class,
        which picks up the company font (TH-SarabunPSK) from the bundle CSS.
    -->
    <template id="bc_booking_layout">
        <t t-if="not company">
            <t t-if="company_id">
                <t t-set="company" t-value="company_id"/>
            </t>
            <t t-elif="o and 'company_id' in o and o.company_id.sudo()">
                <t t-set="company" t-value="o.company_id.sudo()"/>
            </t>
            <t t-else="">
                <t t-set="company" t-value="res_company"/>
            </t>
        </t>
        <div t-attf-class="header o_standard_header o_company_#{company.id}_layout">
            <div class="text-end" style="font-family:'TH-SarabunPSK';font-size:18pt;">
                <span style="text-align:right;font-size:20pt;margin:0 0 4pt 0;">(ต้นฉบับ)</span>
                <br/>
                <span style="text-align:right;margin:0 0 4pt 0; font-size:20pt;">
                    <span>เลขที่</span>
                    <span t-esc="o.name" style="font-weight:bold;"/>
                </span>
            </div>
        </div>
        <div t-attf-class="article o_report_layout_standard o_company_#{company.id}_layout" t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id" t-att-data-oe-lang="o and o.env.context.get('lang')">
            <t t-out="0"/>
        </div>
        <div t-attf-class="footer o_standard_footer o_company_#{company.id}_layout">
            <div class="text-end" style="font-family:'TH-SarabunPSK';font-size:18pt;">
                <span>หน้าที่</span>
                <span class="page"/>
 /                <span class="topage"/>
            </div>
        </div>
    </template>

</odoo>
