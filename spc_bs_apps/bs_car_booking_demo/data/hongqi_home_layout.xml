            <field name="video_filename">ehs9_cabin_teaser.webm</field>
            <field name="video_file" type="base64" file="bs_car_booking_demo/static/src/video/ehs9_cabin_teaser.webm"/>
            <field name="image" type="base64" file="bs_car_booking_demo/static/src/img/cars/hongqi/ehs9_interior.jpg"/>
        </record>

        <record id="home_section_heritage" model="bs.car.website.section">
