<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="group_bs_api_testdrive_manager" model="res.groups">
            <field name="name">Test Drive Manager</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- System admins inherit manager rights automatically -->
        <record id="base.group_system" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('group_bs_api_testdrive_manager'))]"/>
        </record>

    </data>
</odoo>
