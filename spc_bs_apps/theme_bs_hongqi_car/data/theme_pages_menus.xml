<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="hongqi_home_view" model="theme.ir.ui.view">
            <field name="name">Hongqi Car Home</field>
            <field name="key">theme_bs_hongqi_car.hongqi_home</field>
            <field name="type">qweb</field>
            <field name="arch" type="xml">
                <t t-name="theme_bs_hongqi_car.hongqi_home">
                    <t t-call="website.layout">
                        <t t-set="title">Hongqi Thailand</t>
                        <t t-set="bs_hero_overlay" t-value="True"/>
                        <div id="wrap">
                            <!-- Data-driven sections (managed via backend Section records, NOT the
                                 builder). They use t-call, so they must NOT sit inside an oe_structure
                                 or the editor turns the whole region read-only. -->
                            <t t-call="bs_car_booking.home_sections_content"/>
                            <!-- Builder drop zone: free-form Odoo snippets can be dropped/saved here
                                 (per website), while the cinematic sections above stay data-driven. -->
                            <div class="oe_structure" id="oe_structure_hongqi_home"/>
                        </div>
                    </t>
                </t>
            </field>
        </record>
        <record id="hongqi_home_page" model="theme.website.page">
            <field name="url">/showroom</field>
            <field name="view_id" ref="hongqi_home_view"/>
            <field name="is_published">True</field>
        </record>

        <record id="privacy_policy_view" model="theme.ir.ui.view">
            <field name="name">Hongqi Privacy Policy</field>
            <field name="key">theme_bs_hongqi_car.privacy_policy</field>
            <field name="type">qweb</field>
            <field name="arch" type="xml">
                <t t-name="theme_bs_hongqi_car.privacy_policy">
                    <t t-call="website.layout">
                        <t t-set="title">Privacy Policy</t>
                        <div id="wrap" class="oe_structure">
                            <section class="container py-5">
                                <h1>Privacy Policy</h1>
                                <p>This page explains how customer information is collected and used during the vehicle booking journey.</p>
                                <p>Update this page in Website Builder before using it in production.</p>
                            </section>
                        </div>
                    </t>
                </t>
            </field>
        </record>
        <record id="privacy_policy_page" model="theme.website.page">
            <field name="url">/privacy</field>
            <field name="view_id" ref="privacy_policy_view"/>
            <field name="is_published">True</field>
        </record>

        <record id="terms_view" model="theme.ir.ui.view">
            <field name="name">Hongqi Terms</field>
            <field name="key">theme_bs_hongqi_car.terms</field>
            <field name="type">qweb</field>
            <field name="arch" type="xml">
                <t t-name="theme_bs_hongqi_car.terms">
                    <t t-call="website.layout">
                        <t t-set="title">Terms and Conditions</t>
                        <div id="wrap" class="oe_structure">
                            <section class="container py-5">
                                <h1>Terms and Conditions</h1>
                                <p>These terms govern vehicle reservations and booking deposit payments.</p>
                            </section>
                        </div>
                    </t>
                </t>
            </field>
        </record>
        <record id="terms_page" model="theme.website.page">
            <field name="url">/terms</field>
            <field name="view_id" ref="terms_view"/>
            <field name="is_published">True</field>
        </record>

        <record id="refund_policy_view" model="theme.ir.ui.view">
            <field name="name">Hongqi Refund Policy</field>
            <field name="key">theme_bs_hongqi_car.refund_policy</field>
            <field name="type">qweb</field>
            <field name="arch" type="xml">
                <t t-name="theme_bs_hongqi_car.refund_policy">
                    <t t-call="website.layout">
                        <t t-set="title">Refund Policy</t>
                        <div id="wrap" class="oe_structure">
                            <section class="container py-5">
                                <h1>Refund Policy</h1>
                                <p>This policy explains when and how a booking deposit may be refunded.</p>
                            </section>
                        </div>
                    </t>
                </t>
            </field>
        </record>
        <record id="refund_policy_page" model="theme.website.page">
            <field name="url">/refund-policy</field>
            <field name="view_id" ref="refund_policy_view"/>
            <field name="is_published">True</field>
        </record>

        <record id="cancellation_policy_view" model="theme.ir.ui.view">
            <field name="name">Hongqi Cancellation Policy</field>
            <field name="key">theme_bs_hongqi_car.cancellation_policy</field>
            <field name="type">qweb</field>
            <field name="arch" type="xml">
                <t t-name="theme_bs_hongqi_car.cancellation_policy">
                    <t t-call="website.layout">
                        <t t-set="title">Cancellation Policy</t>
                        <div id="wrap" class="oe_structure">
                            <section class="container py-5">
                                <h1>Cancellation Policy</h1>
                                <p>This policy explains booking cancellation handling before and after dealer confirmation.</p>
                            </section>
                        </div>
                    </t>
                </t>
            </field>
        </record>
        <record id="cancellation_policy_page" model="theme.website.page">
            <field name="url">/cancellation-policy</field>
            <field name="view_id" ref="cancellation_policy_view"/>
            <field name="is_published">True</field>
        </record>

        <record id="contact_us_view" model="theme.ir.ui.view">
            <field name="name">Hongqi Contact Us</field>
            <field name="key">theme_bs_hongqi_car.contact_us</field>
            <field name="type">qweb</field>
            <field name="arch" type="xml">
                <t t-name="theme_bs_hongqi_car.contact_us">
                    <t t-call="website.layout">
                        <t t-set="title">Contact Hongqi Thailand</t>
                        <div id="wrap" class="oe_structure">
                            <section class="bs_contact_page">
                                <div class="container">
                                    <div class="bs_contact_shell">
                                        <div class="bs_contact_intro">
                                            <img class="bs_contact_logo"
                                                 src="/theme_bs_hongqi_car/static/src/img/brand/logo_white_gold.png"
                                                 alt="Hongqi Metro Group"/>
                                            <span class="car_kicker">Connect With Us</span>
                                            <h1>Registration / Contact Us</h1>
                                            <p>
                                                กรุณาเลือกหัวข้อที่ท่านสนใจและกรอกข้อมูลด้านล่าง<br/>
                                                Please select your interest and fill out the details below.
                                            </p>
                                        </div>

                                        <section class="s_website_form bs_contact_form" data-vcss="001" data-snippet="s_website_form">
                                            <form id="hongqi_contact_form"
                                                  action="/website/form/"
                                                  method="post"
                                                  enctype="multipart/form-data"
                                                  class="o_mark_required"
                                                  data-mark="*"
                                                  data-model_name="crm.lead"
                                                  data-success-mode="message"
                                                  data-success-page="/contactus-thank-you"
                                                  data-pre-fill="true">
                                                <input type="hidden" class="s_website_form_input" name="description" value="Submitted from Hongqi Thailand contact page."/>
                                                <!-- Topic tag is stamped SERVER-SIDE from the selected topic
                                                     (crm_lead.website_form_input_filter) — a hidden tag input
                                                     would be trivially tampered with. -->
                                                <div class="s_website_form_rows row s_col_no_bgcolor">
                                                    <!-- MUST be a s_website_form_field: the form framework binds its
                                                         input listener on that class, and the conditional visibility
                                                         of the dealer fields re-evaluates only on those events. -->
                                                    <div data-name="Field"
                                                         class="s_website_form_field mb-4 col-12 s_website_form_required"
                                                         data-type="char"
                                                         data-translated-name="Topic">
                                                        <div class="bs_contact_topics">
                                                            <div class="bs_contact_topic">
                                                                <input class="s_website_form_input bs_contact_radio"
                                                                       type="radio"
                                                                       name="name"
                                                                       id="topic_dealer"
                                                                       value="Dealership Application"
                                                                       required="1"
                                                                       checked="checked"/>
                                                                <label for="topic_dealer">
                                                                    <strong>สมัครเป็นผู้แทนจำหน่าย / Dealership Application</strong>
                                                                </label>
                                                            </div>
                                                            <div class="bs_contact_topic">
                                                                <input class="s_website_form_input bs_contact_radio"
                                                                       type="radio"
                                                                       name="name"
                                                                       id="topic_job"
                                                                       value="Job Application"
                                                                       required="1"/>
                                                                <label for="topic_job">
                                                                    <strong>สมัครงาน / Job Application</strong>
                                                                </label>
                                                            </div>
                                                            <div class="bs_contact_topic">
                                                                <input class="s_website_form_input bs_contact_radio"
                                                                       type="radio"
                                                                       name="name"
                                                                       id="topic_other"
                                                                       value="Other"
                                                                       required="1"/>
                                                                <label for="topic_other">
                                                                    <strong>อื่น ๆ / Other</strong>
                                                                    <span>กรุณาระบุรายละเอียด / Please describe your inquiry</span>
                                                                </label>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div data-name="Field"
                                                         class="s_website_form_field mb-4 col-md-6 s_website_form_required"
                                                         data-type="char"
                                                         data-translated-name="Full Name">
                                                        <label class="form-label" for="contact_name">ชื่อ-นามสกุล / Full Name <span class="text-danger">*</span></label>
                                                        <input class="form-control s_website_form_input bs_contact_input"
                                                               type="text"
                                                               name="contact_name"
                                                               required="1"
                                                               id="contact_name"
                                                               placeholder="ชื่อ-นามสกุล / John Doe"/>
                                                    </div>
                                                    <div data-name="Field"
                                                         class="s_website_form_field mb-4 col-md-6 s_website_form_required"
                                                         data-type="tel"
                                                         data-translated-name="Phone Number">
                                                        <label class="form-label" for="phone">เบอร์โทรศัพท์ / Phone Number <span class="text-danger">*</span></label>
                                                        <input class="form-control s_website_form_input bs_contact_input"
                                                               type="tel"
                                                               name="phone"
                                                               required="1"
                                                               id="phone"
                                                               placeholder="08X-XXX-XXXX / +66"/>
                                                    </div>

                                                    <div data-name="Field"
                                                         class="s_website_form_field mb-4 col-md-6"
                                                         data-type="char"
                                                         data-translated-name="Line ID">
                                                        <label class="form-label" for="line_id">Line ID</label>
                                                        <input class="form-control s_website_form_input bs_contact_input"
                                                               type="text"
                                                               name="Line ID"
                                                               id="line_id"
                                                               placeholder="Line ID (Optional)"/>
                                                    </div>
                                                    <div data-name="Field"
                                                         class="s_website_form_field mb-4 col-md-6 s_website_form_required"
                                                         data-type="email"
                                                         data-translated-name="Email">
                                                        <label class="form-label" for="email_from">อีเมล / Email <span class="text-danger">*</span></label>
                                                        <input class="form-control s_website_form_input bs_contact_input"
                                                               type="email"
                                                               name="email_from"
                                                               required="1"
                                                               id="email_from"
                                                               placeholder="example@email.com"/>
                                                    </div>

                                                    <!-- Dealership-only fields, via the form framework's NATIVE
                                                         conditional visibility (s_website_form_field_hidden_if +
                                                         data-visibility-*): the framework reactively strips any
                                                         hand-managed d-none/disabled on s_website_form_field, so
                                                         fighting it with custom JS does not work. It also disables
                                                         hidden inputs (excluded from submit and validation). -->
                                                    <div data-name="Field"
                                                         class="s_website_form_field mb-4 col-12 s_website_form_required s_website_form_field_hidden_if d-none bs_contact_dealer_field"
                                                         data-type="char"
                                                         data-translated-name="Proposed Location"
                                                         data-visibility-dependency="name"
                                                         data-visibility-comparator="equal"
                                                         data-visibility-condition="Dealership Application">
                                                        <label class="form-label" for="proposed_location">พิกัด/พื้นที่ที่ต้องการเปิดโชว์รูม / Proposed Location <span class="text-danger">*</span></label>
                                                        <!-- This website's published dealer areas (same public scope
                                                             as the dealer locator: current website + its company). -->
                                                        <t t-set="bs_contact_dealers"
                                                           t-value="env['bs.car.dealer'].sudo().with_context(website_id=website.id).search([('active', '=', True), ('website_published', '=', True), ('company_id', 'in', [False, website.company_id.id])], order='sequence, id')"/>
                                                        <select class="form-select s_website_form_input bs_contact_input"
                                                                name="Proposed Location"
                                                                id="proposed_location"
                                                                required="1">
                                                            <option value="">— เลือกพื้นที่ / Select Location —</option>
                                                            <t t-foreach="bs_contact_dealers" t-as="bs_dealer">
                                                                <option t-att-value="'%s%s' % (bs_dealer.name, bs_dealer.city and ' (%s)' % bs_dealer.city or '')">
                                                                    <t t-esc="bs_dealer.name"/><t t-if="bs_dealer.city"> — <t t-esc="bs_dealer.city"/></t>
                                                                </option>
                                                            </t>
                                                        </select>
                                                    </div>
                                                    <div data-name="Field"
                                                         class="s_website_form_field mb-4 col-12 s_website_form_field_hidden_if d-none bs_contact_dealer_field"
                                                         data-type="binary"
                                                         data-translated-name="Attachment"
                                                         data-visibility-dependency="name"
                                                         data-visibility-comparator="equal"
                                                         data-visibility-condition="Dealership Application">
                                                        <label class="form-label" for="contact_attachment">แนบเอกสารนำเสนอ/โปรไฟล์บริษัท (Company Profile) / Max 5MB (PDF)</label>
                                                        <input class="form-control s_website_form_input bs_contact_input"
                                                               type="file"
                                                               name="Attachment"
                                                               id="contact_attachment"
                                                               accept=".pdf"/>
                                                    </div>

                                                    <!-- Job Application CV upload. -->
                                                    <div data-name="Field"
                                                         class="s_website_form_field mb-4 col-12 s_website_form_required s_website_form_field_hidden_if d-none"
                                                         data-type="binary"
                                                         data-translated-name="CV Attachment"
                                                         data-visibility-dependency="name"
                                                         data-visibility-comparator="equal"
                                                         data-visibility-condition="Job Application">
                                                        <label class="form-label" for="contact_cv">แนบ CV/Resume <span class="text-danger">*</span> / Max 5MB (PDF, DOC, DOCX)</label>
                                                        <input class="form-control s_website_form_input bs_contact_input"
                                                               type="file"
                                                               name="Attachment"
                                                               id="contact_cv"
                                                               required="1"
                                                               accept=".pdf,.doc,.docx"/>
                                                    </div>

                                                    <!-- "Other" topic message: required when the customer
                                                         selects Other, hidden for all other topics. -->
                                                    <div data-name="Field"
                                                         class="s_website_form_field mb-4 col-12 s_website_form_required s_website_form_field_hidden_if d-none"
                                                         data-type="text"
                                                         data-translated-name="Message"
                                                         data-visibility-dependency="name"
                                                         data-visibility-comparator="equal"
                                                         data-visibility-condition="Other">
                                                        <label class="form-label" for="contact_message">รายละเอียด / Message <span class="text-danger">*</span></label>
                                                        <textarea class="form-control s_website_form_input bs_contact_input"
                                                                  name="contact_message"
                                                                  id="contact_message"
                                                                  required="1"
                                                                  rows="4"
                                                                  placeholder="กรุณาระบุรายละเอียดที่ท่านต้องการสอบถาม / Please describe your inquiry..."></textarea>
                                                    </div>

                                                    <!-- A s_website_form_field so the framework's required-validation
                                                         actually checks the consent (a plain div is skipped). -->
                                                    <div data-name="Field"
                                                         class="s_website_form_field s_website_form_required mb-5 col-12"
                                                         data-type="char"
                                                         data-translated-name="Privacy Consent">
                                                        <div class="bs_contact_consent">
                                                            <input class="s_website_form_input"
                                                                   type="checkbox"
                                                                   name="Privacy Consent"
                                                                   value="Accepted"
                                                                   required="1"
                                                                   id="privacy_consent"/>
                                                            <label for="privacy_consent">
                                                                ข้าพเจ้ายินยอมให้ <strong>Metro Group</strong> เก็บรวบรวมและใช้ข้อมูลส่วนบุคคล เพื่อการติดต่อกลับและนำเสนอข้อมูล ตาม
                                                                <a href="/privacy">นโยบายความเป็นส่วนตัว</a> <span class="text-danger">*</span><br/>
                                                                I consent to data collection for communication purposes in accordance with the
                                                                <a href="/privacy">Privacy Policy</a>. <span class="text-danger">*</span>
                                                            </label>
                                                        </div>
                                                    </div>

                                                    <div class="col-12 s_website_form_submit" data-name="Submit Button">
                                                        <a href="#" role="button" class="btn bs_contact_submit s_website_form_send">ตกลง / Submit</a>
                                                        <span id="s_website_form_result" class="me-2 small text-danger"/>
                                                    </div>
                                                </div>
                                            </form>

                                            <div class="s_website_form_end_message d-none">
                                                <div class="oe_structure">
                                                    <section class="bs_contact_success text-center">
                                                        <i class="fa fa-check-circle fa-4x mb-4" role="img" aria-hidden="true" title="Success"/>
                                                        <h2>ส่งข้อมูลสำเร็จ! / Successfully Submitted!</h2>
                                                        <p>ทีมงานของเราจะติดต่อกลับหาท่านโดยเร็วที่สุด<br/>Our team will get back to you as soon as possible.</p>
                                                    </section>
                                                </div>
                                            </div>
                                        </section>
                                    </div>
                                </div>
                            </section>
                        </div>
                    </t>
                </t>
            </field>
        </record>
        <record id="contact_us_page" model="theme.website.page">
            <field name="url">/contactus</field>
            <field name="view_id" ref="contact_us_view"/>
            <field name="is_published">True</field>
        </record>

        <record id="about_us_view" model="theme.ir.ui.view">
            <field name="name">Hongqi About Us</field>
            <field name="key">theme_bs_hongqi_car.about_us</field>
            <field name="type">qweb</field>
            <field name="arch" type="xml">
                <t t-name="theme_bs_hongqi_car.about_us">
                    <t t-call="website.layout">
                        <t t-set="title">About Hongqi Thailand</t>
                        <div id="wrap" class="oe_structure">
                            <section class="bs_about_page">
                                <div class="container">
                                    <span class="car_kicker">Metro Group Presents</span>
                                    <h1>Hongqi Thailand</h1>
                                    <p>Official HONGQI dealer in Thailand by Metro Group, presenting flagship luxury with heritage-led design and modern electric performance.</p>
                                </div>
                            </section>
                        </div>
                    </t>
                </t>
            </field>
        </record>
        <record id="about_us_page" model="theme.website.page">
            <field name="url">/about-us</field>
            <field name="view_id" ref="about_us_view"/>
            <field name="is_published">True</field>
        </record>

        <!-- ── Test Drive Page ──────────────────────────────────────── -->
        <record id="test_drive_view" model="theme.ir.ui.view">
            <field name="name">Hongqi Test Drive</field>
            <field name="key">theme_bs_hongqi_car.test_drive</field>
            <field name="type">qweb</field>
            <field name="arch" type="xml">
                <t t-name="theme_bs_hongqi_car.test_drive">
                    <t t-call="website.layout">
                        <t t-set="title">Test Drive | Hongqi Thailand</t>
                        <div id="wrap">
                            <div class="bs_testdrive_page">
                                <div class="form-container">
                                    <div class="header-logos">
                                        <img src="/theme_bs_hongqi_car/static/src/img/brand/hongqi_metro_white.png" alt="Hongqi Metro Group"/>
                                    </div>

                                    <h2>นัดหมายทดลองขับ<br/><span style="font-size:20px;color:#b3b3b3;">Book a Test Drive</span></h2>
                                    <div class="subtitle">
                                        สัมผัสประสบการณ์แห่งความหรูหราเหนือระดับ กรุณากรอกข้อมูลของท่านด้านล่าง<br/>
                                        Experience the ultimate luxury. Please fill out your details below.
                                    </div>

                                    <form id="testDriveForm">
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label>ชื่อ-นามสกุล <span class="en-label">/ Full Name</span><span class="required">*</span></label>
                                                <input type="text" id="td_fullName" placeholder="ชื่อ-นามสกุล / John Doe" required="required"/>
                                            </div>
                                            <div class="form-group">
                                                <label>เบอร์โทรศัพท์ <span class="en-label">/ Phone Number</span><span class="required">*</span></label>
                                                <input type="tel" id="td_phone" placeholder="08X-XXX-XXXX / +66" required="required" inputmode="numeric" pattern="[0-9+\-\s]{7,15}"/>
                                            </div>
                                        </div>

                                        <div class="form-row">
                                            <div class="form-group">
                                                <label>Line ID</label>
                                                <input type="text" id="td_lineId" placeholder="Line ID (Optional)"/>
                                            </div>
                                            <div class="form-group">
                                                <label>อีเมล <span class="en-label">/ Email</span></label>
                                                <input type="email" id="td_email" placeholder="example@email.com (Optional)"/>
                                            </div>
                                        </div>

                                        <div class="form-row">
                                            <div class="form-group">
                                                <label>วันที่สะดวก <span class="en-label">/ Preferred Date</span><span class="required">*</span></label>
                                                <input type="date" id="td_date" required="required"/>
                                            </div>
                                            <div class="form-group">
                                                <label>ช่วงเวลาที่สะดวก <span class="en-label">/ Preferred Time</span><span class="required">*</span></label>
                                                <div class="radio-group">
                                                    <label class="radio-item">
                                                        <input type="radio" name="preferredTime" value="Morning" checked="checked"/>
                                                        <div>ช่วงเช้า / Morning<br/><span style="font-size:12px;color:#888;">(09:00 - 12:00)</span></div>
                                                    </label>
                                                    <label class="radio-item">
                                                        <input type="radio" name="preferredTime" value="Afternoon"/>
                                                        <div>ช่วงบ่าย / Afternoon<br/><span style="font-size:12px;color:#888;">(13:00 - 17:00)</span></div>
                                                    </label>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="form-row">
                                            <div class="form-group">
                                                <label>พื้นที่นัดหมาย <span class="en-label">/ Preferred Location</span><span class="required">*</span></label>
                                                <input type="text" id="td_location" placeholder="เช่น บางนา, สุขุมวิท / e.g., Bangna, Sukhumvit" required="required"/>
                                            </div>
                                        </div>

                                        <div class="consent-row">
                                            <input type="checkbox" id="td_consent" required="required"/>
                                            <label for="td_consent" class="consent-label">
