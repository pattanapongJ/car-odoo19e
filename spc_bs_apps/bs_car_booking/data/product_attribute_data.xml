<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- ============================================================
             STANDARD CAR CONFIGURATION ATTRIBUTES
             Standard Package drives the product variant (dynamic); the rest are
             priced options stored on the sale order line (no_variant).
             Per-model price_extra is set when the product is generated.
             ============================================================ -->

        <!-- STANDARD PACKAGE (per-model values come from bs.car.variant) -->
        <record id="attr_trim" model="product.attribute">
            <field name="name">Standard Package</field>
            <field name="display_type">radio</field>
            <field name="create_variant">dynamic</field>
            <field name="sequence">10</field>
        </record>

        <!-- EXTERIOR COLOR -->
        <record id="attr_color" model="product.attribute">
            <field name="name">Exterior Color</field>
            <field name="display_type">color</field>
            <field name="create_variant">no_variant</field>
            <field name="sequence">20</field>
        </record>
        <!-- INTERIOR -->
        <record id="attr_interior" model="product.attribute">
            <field name="name">Interior</field>
            <field name="display_type">radio</field>
            <field name="create_variant">no_variant</field>
            <field name="sequence">30</field>
        </record>

        <!-- WHEELS -->
        <record id="attr_wheels" model="product.attribute">
            <field name="name">Wheels</field>
            <field name="display_type">radio</field>
            <field name="create_variant">no_variant</field>
            <field name="sequence">40</field>
        </record>

        <!-- ADD-ONS (multi-select) -->
        <record id="attr_addons" model="product.attribute">
            <field name="name">Add-ons</field>
            <field name="display_type">multi</field>
            <field name="create_variant">no_variant</field>
            <field name="sequence">50</field>
        </record>
    </data>
</odoo>
