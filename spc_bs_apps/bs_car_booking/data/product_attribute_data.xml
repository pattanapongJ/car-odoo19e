<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- ============================================================
             STANDARD CAR CONFIGURATION ATTRIBUTES
             Trim drives the product variant (dynamic); the rest are
             priced options stored on the sale order line (no_variant).
             Per-model price_extra is set when the product is generated.
             ============================================================ -->

        <!-- TRIM (per-model values come from bs.car.variant) -->
        <record id="attr_trim" model="product.attribute">
            <field name="name">Trim</field>
            <field name="display_type">radio</field>
            <field name="create_variant">dynamic</field>
            <field name="sequence">10</field>
        </record>

        <!-- EXTERIOR COLOR -->
        <record id="attr_color" model="product.attribute">
            <field name="name">Exterior Color</field>
            <field name="display_type">color</field>
            <field name="create_variant">no_variant</field>
            <field name="sequence">20</field>
        </record>
        <record id="val_color_white" model="product.attribute.value">
            <field name="attribute_id" ref="attr_color"/>
            <field name="name">Pearl White Multi-Coat</field>
            <field name="html_color">#E8E8E8</field><field name="sequence">10</field>
        </record>
        <record id="val_color_black" model="product.attribute.value">
            <field name="attribute_id" ref="attr_color"/>
            <field name="name">Solid Black</field>
            <field name="html_color">#0A0A0A</field><field name="sequence">20</field>
        </record>
        <record id="val_color_grey" model="product.attribute.value">
            <field name="attribute_id" ref="attr_color"/>
            <field name="name">Stealth Grey</field>
            <field name="html_color">#5A5E63</field><field name="sequence">30</field>
        </record>
        <record id="val_color_blue" model="product.attribute.value">
            <field name="attribute_id" ref="attr_color"/>
            <field name="name">Deep Blue Metallic</field>
            <field name="html_color">#25344F</field><field name="sequence">40</field>
        </record>
        <record id="val_color_red" model="product.attribute.value">
            <field name="attribute_id" ref="attr_color"/>
            <field name="name">Ultra Red</field>
            <field name="html_color">#A30D14</field><field name="sequence">50</field>
        </record>
        <record id="val_color_silver" model="product.attribute.value">
            <field name="attribute_id" ref="attr_color"/>
            <field name="name">Quicksilver</field>
            <field name="html_color">#B4B7BA</field><field name="sequence">60</field>
        </record>

        <!-- INTERIOR -->
        <record id="attr_interior" model="product.attribute">
            <field name="name">Interior</field>
            <field name="display_type">radio</field>
            <field name="create_variant">no_variant</field>
            <field name="sequence">30</field>
        </record>
        <record id="val_int_black" model="product.attribute.value">
            <field name="attribute_id" ref="attr_interior"/>
            <field name="name">All Black</field><field name="sequence">10</field>
        </record>
        <record id="val_int_white" model="product.attribute.value">
            <field name="attribute_id" ref="attr_interior"/>
            <field name="name">Black &amp; White</field><field name="sequence">20</field>
        </record>
        <record id="val_int_cream" model="product.attribute.value">
            <field name="attribute_id" ref="attr_interior"/>
            <field name="name">Cream</field><field name="sequence">30</field>
        </record>

        <!-- WHEELS -->
        <record id="attr_wheels" model="product.attribute">
            <field name="name">Wheels</field>
            <field name="display_type">radio</field>
            <field name="create_variant">no_variant</field>
            <field name="sequence">40</field>
        </record>
        <record id="val_wheel_aero" model="product.attribute.value">
            <field name="attribute_id" ref="attr_wheels"/>
            <field name="name">18&quot; Aero Wheels</field><field name="sequence">10</field>
        </record>
        <record id="val_wheel_sport" model="product.attribute.value">
            <field name="attribute_id" ref="attr_wheels"/>
            <field name="name">19&quot; Sport Wheels</field><field name="sequence">20</field>
        </record>
        <record id="val_wheel_induction" model="product.attribute.value">
            <field name="attribute_id" ref="attr_wheels"/>
            <field name="name">20&quot; Induction Wheels</field><field name="sequence">30</field>
        </record>
        <record id="val_wheel_perf" model="product.attribute.value">
            <field name="attribute_id" ref="attr_wheels"/>
            <field name="name">21&quot; Performance Wheels</field><field name="sequence">40</field>
        </record>

        <!-- ADD-ONS (multi-select) -->
        <record id="attr_addons" model="product.attribute">
            <field name="name">Add-ons</field>
            <field name="display_type">multi</field>
            <field name="create_variant">no_variant</field>
            <field name="sequence">50</field>
        </record>
        <record id="val_addon_fsd" model="product.attribute.value">
            <field name="attribute_id" ref="attr_addons"/>
            <field name="name">Full Self-Driving (Supervised)</field><field name="sequence">10</field>
        </record>
        <record id="val_addon_tow" model="product.attribute.value">
            <field name="attribute_id" ref="attr_addons"/>
            <field name="name">Tow Package</field><field name="sequence">20</field>
        </record>
        <record id="val_addon_connect" model="product.attribute.value">
            <field name="attribute_id" ref="attr_addons"/>
            <field name="name">Premium Connectivity (1 yr)</field><field name="sequence">30</field>
        </record>
        <record id="val_addon_ppf" model="product.attribute.value">
            <field name="attribute_id" ref="attr_addons"/>
            <field name="name">Paint Protection Film</field><field name="sequence">40</field>
        </record>
    </data>
</odoo>
