<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="otp_purpose_booking" model="bs.car.booking.otp.purpose">
            <field name="name">Booking Verification</field>
            <field name="code">booking</field>
            <field name="sequence">1</field>
            <field name="sms_template_id" ref="sms_template_otp_booking"/>
            <field name="sms_fallback_body">Your booking verification code is: %(otp_code)s. Valid for 5 minutes.</field>
        </record>

        <record id="otp_purpose_tracking" model="bs.car.booking.otp.purpose">
            <field name="name">Tracking Access</field>
            <field name="code">tracking</field>
            <field name="sequence">2</field>
            <field name="sms_template_id" ref="sms_template_otp_tracking"/>
            <field name="sms_fallback_body">Your booking tracking code is: %(otp_code)s. Valid for 5 minutes.</field>
        </record>

    </data>
</odoo>
