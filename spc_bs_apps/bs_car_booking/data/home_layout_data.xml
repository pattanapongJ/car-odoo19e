<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Default home layout — rendered by /showroom. Each section uses the
             "Featured on Home" model by default; set a Car Model per section
             (Master Data > Home Layout) for a multi-model home. -->
        <record id="home_block_hero" model="bs.car.home.block">
            <field name="block_type">featured_hero</field>
            <field name="sequence">10</field>
        </record>
        <record id="home_block_model_stage" model="bs.car.home.block">
            <field name="block_type">model_stage</field>
            <field name="sequence">20</field>
        </record>
        <record id="home_block_color_studio" model="bs.car.home.block">
            <field name="block_type">color_studio</field>
            <field name="sequence">30</field>
        </record>
        <record id="home_block_specs" model="bs.car.home.block">
            <field name="block_type">specs</field>
            <field name="sequence">40</field>
        </record>
        <record id="home_block_highlights" model="bs.car.home.block">
            <field name="block_type">highlights</field>
            <field name="sequence">50</field>
        </record>
        <record id="home_block_cabin_story" model="bs.car.home.block">
            <field name="block_type">cabin_story</field>
            <field name="sequence">60</field>
        </record>
        <record id="home_block_stories" model="bs.car.home.block">
            <field name="block_type">stories</field>
            <field name="sequence">70</field>
        </record>
        <record id="home_block_dealers" model="bs.car.home.block">
            <field name="block_type">dealers</field>
            <field name="sequence">80</field>
        </record>
        <record id="home_block_gallery" model="bs.car.home.block">
            <field name="block_type">gallery</field>
            <field name="sequence">90</field>
            <field name="active">0</field>
        </record>
        <record id="home_block_heritage" model="bs.car.home.block">
            <field name="block_type">heritage</field>
            <field name="sequence">100</field>
            <field name="active">0</field>
        </record>
        <record id="home_block_stats" model="bs.car.home.block">
            <field name="block_type">stats</field>
            <field name="sequence">110</field>
            <field name="active">0</field>
        </record>
        <record id="home_block_browse" model="bs.car.home.block">
            <field name="block_type">browse</field>
            <field name="sequence">120</field>
            <field name="active">0</field>
        </record>
        <record id="home_block_arrivals" model="bs.car.home.block">
            <field name="block_type">arrivals</field>
            <field name="sequence">130</field>
            <field name="active">0</field>
        </record>
        <record id="home_block_offers" model="bs.car.home.block">
            <field name="block_type">offers</field>
            <field name="sequence">140</field>
            <field name="active">0</field>
        </record>
        <record id="home_block_finance" model="bs.car.home.block">
            <field name="block_type">finance</field>
            <field name="sequence">150</field>
            <field name="active">0</field>
        </record>
        <record id="home_block_lineup" model="bs.car.home.block">
            <field name="block_type">lineup</field>
            <field name="sequence">65</field>
        </record>
    </data>
</odoo>
