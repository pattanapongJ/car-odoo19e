<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Car Variant Form & Tree -->
    <record id="view_bs_car_variant_tree" model="ir.ui.view">
        <field name="name">bs.car.variant.tree</field>
        <field name="model">bs.car.variant</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="model_id"/>
                <field name="brand_id"/>
                <field name="exterior_color"/>
                <field name="price" widget="monetary"/>
                <field name="available_qty"/>
                <field name="estimated_delivery_days"/>
                <field name="website_published"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_bs_car_variant_form" model="ir.ui.view">
        <field name="name">bs.car.variant.form</field>
        <field name="model">bs.car.variant</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Variant Name"/></h1>
                        <h3>
                            <field name="model_id" domain="[('brand_id', '=', brand_id)]" context="{'default_brand_id': brand_id}"/>
                        </h3>
                    </div>
                    <notebook>
                        <page string="General">
                            <group>
                                <group>
                                    <field name="sequence"/>
                                    <field name="price" widget="monetary"/>
                                    <field name="price_over_base" widget="monetary"/>
                                    <field name="website_published"/>
                                    <field name="active"/>
                                </group>
                                <group>
                                    <field name="exterior_color"/>
                                    <field name="exterior_color_code" widget="color"/>
                                    <field name="interior_color"/>
                                    <field name="wheel_type"/>
                                </group>
                            </group>
                        </page>
                        <page string="Specifications">
                            <group>
                                <field name="range_km"/>
                                <field name="acceleration"/>
                                <field name="top_speed"/>
                            </group>
                        </page>
                        <page string="Inventory">
                            <group>
                                <field name="available_qty"/>
                                <field name="estimated_delivery_days"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_bs_car_variant" model="ir.actions.act_window">
        <field name="name">Car Variants</field>
        <field name="res_model">bs.car.variant</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_bs_car_variant_tree"/>
    </record>
</odoo>
