<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bs_car_showcase_item_list" model="ir.ui.view">
        <field name="name">bs.car.showcase.item.list</field>
        <field name="model">bs.car.showcase.item</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="model_id"/>
                <field name="item_type"/>
                <field name="name"/>
                <field name="swatch_color" optional="show"/>
                <field name="website_published" widget="boolean_toggle"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_bs_car_showcase_item_form" model="ir.ui.view">
        <field name="name">bs.car.showcase.item.form</field>
        <field name="model">bs.car.showcase.item</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="model_id" options="{'no_create': True}"/>
                            <field name="item_type"/>
                            <field name="sequence"/>
                            <field name="website_published"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="image" widget="image" class="oe_avatar"/>
                            <field name="image_alt"/>
                            <field name="swatch_color"
                                   invisible="item_type not in ('exterior', 'interior')"
                                   placeholder="#111111"/>
                        </group>
                    </group>
                    <group>
                        <field name="subtitle"/>
                        <field name="description" widget="html"/>
                    </group>
                    <group string="CTA">
                        <field name="cta_label"/>
                        <field name="cta_url"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_bs_car_showcase_item_search" model="ir.ui.view">
        <field name="name">bs.car.showcase.item.search</field>
        <field name="model">bs.car.showcase.item</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="model_id"/>
                <filter name="published" string="Published" domain="[('website_published', '=', True), ('active', '=', True)]"/>
                <separator/>
                <group>
                    <filter name="group_model" string="Model" context="{'group_by': 'model_id'}"/>
                    <filter name="group_type" string="Type" context="{'group_by': 'item_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_bs_car_showcase_item" model="ir.actions.act_window">
        <field name="name">Showcase Items</field>
        <field name="res_model">bs.car.showcase.item</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Add campaign showcase content</p>
            <p>Use these records for the model stage, colour studio, highlights and cabin story sections.</p>
        </field>
    </record>

    <record id="view_bs_car_story_list" model="ir.ui.view">
        <field name="name">bs.car.story.list</field>
        <field name="model">bs.car.story</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="model_id"/>
                <field name="publish_date"/>
                <field name="website_published" widget="boolean_toggle"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_bs_car_story_form" model="ir.ui.view">
        <field name="name">bs.car.story.form</field>
        <field name="model">bs.car.story</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="subtitle" placeholder="Gold lead line under the headline"/>
                            <field name="location" placeholder="Changchun, China"/>
                            <field name="model_id" options="{'no_create': True}"/>
                            <field name="publish_date"/>
                            <field name="sequence"/>
                            <field name="website_published"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="image" widget="image" class="oe_avatar"/>
                            <field name="cta_label"/>
                            <field name="cta_url"/>
                        </group>
                    </group>
                    <group>
                        <field name="excerpt"/>
                        <field name="body" widget="html"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_bs_car_story" model="ir.actions.act_window">
        <field name="name">Stories</field>
        <field name="res_model">bs.car.story</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Add brand stories</p>
            <p>Stories appear on the showroom home page and can link to a model or an external story page.</p>
        </field>
    </record>

    <menuitem id="menu_bs_car_showcase_item"
              name="Showcase Items"
              parent="menu_bs_car_booking_master"
              action="action_bs_car_showcase_item"
              sequence="45"/>

    <menuitem id="menu_bs_car_story"
              name="Stories"
              parent="menu_bs_car_booking_master"
              action="action_bs_car_story"
              sequence="46"/>
</odoo>
