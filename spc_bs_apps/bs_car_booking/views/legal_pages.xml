<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Policy pages linked from the booking agreement checkboxes.
         Content is a default template, fully editable in the website builder. -->

    <record id="terms_view" model="ir.ui.view">
        <field name="name">Terms &amp; Conditions</field>
        <field name="type">qweb</field>
        <field name="key">bs_car_booking.terms</field>
        <field name="arch" type="xml">
            <t t-name="bs_car_booking.terms">
                <t t-call="website.layout">
                    <t t-set="title">Terms &amp; Conditions</t>
                    <div id="wrap" class="oe_structure">
                        <section class="s_text_block container py-5">
                            <div class="row"><div class="col-lg-9 mx-auto">
                                <h1>Terms &amp; Conditions</h1>
                                <p>These terms govern the reservation of a vehicle and the payment of a
                                   booking deposit through this website.</p>
                                <h3>Reservation &amp; deposit</h3>
                                <p>The deposit reserves the selected vehicle configuration. It is applied
                                   to the final purchase price upon completion of the sale.</p>
                                <h3>Price &amp; availability</h3>
                                <p>Prices, specifications and availability are indicative and confirmed by
                                   the dealer. The booking does not constitute a binding sale contract.</p>
                                <p><em>Replace this template with your dealership's official Terms &amp;
                                   Conditions.</em></p>
                            </div></div>
                        </section>
                    </div>
                </t>
            </t>
        </field>
    </record>
    <record id="terms_page" model="website.page">
        <field name="name">Terms &amp; Conditions</field>
        <field name="view_id" ref="terms_view"/>
        <field name="url">/terms</field>
        <field name="is_published">True</field>
    </record>

    <record id="refund_policy_view" model="ir.ui.view">
        <field name="name">Refund Policy</field>
        <field name="type">qweb</field>
        <field name="key">bs_car_booking.refund_policy</field>
        <field name="arch" type="xml">
            <t t-name="bs_car_booking.refund_policy">
                <t t-call="website.layout">
                    <t t-set="title">Refund Policy</t>
                    <div id="wrap" class="oe_structure">
                        <section class="s_text_block container py-5">
                            <div class="row"><div class="col-lg-9 mx-auto">
                                <h1>Refund Policy</h1>
                                <p>This policy explains when and how a booking deposit may be refunded.</p>
                                <h3>Refundable cases</h3>
                                <ul>
                                    <li>Vehicle unavailable or specification cannot be fulfilled.</li>
                                    <li>Cancellation within the cooling-off period stated by the dealer.</li>
                                </ul>
                                <h3>Processing</h3>
                                <p>Approved refunds are returned to the original payment method within the
                                   timeframe set by the dealer and the payment provider.</p>
                                <p><em>Replace this template with your dealership's official Refund Policy.</em></p>
                            </div></div>
                        </section>
                    </div>
                </t>
            </t>
        </field>
    </record>
    <record id="refund_policy_page" model="website.page">
        <field name="name">Refund Policy</field>
        <field name="view_id" ref="refund_policy_view"/>
        <field name="url">/refund-policy</field>
        <field name="is_published">True</field>
    </record>

    <record id="cancellation_policy_view" model="ir.ui.view">
        <field name="name">Cancellation Policy</field>
        <field name="type">qweb</field>
        <field name="key">bs_car_booking.cancellation_policy</field>
        <field name="arch" type="xml">
            <t t-name="bs_car_booking.cancellation_policy">
                <t t-call="website.layout">
                    <t t-set="title">Cancellation Policy</t>
                    <div id="wrap" class="oe_structure">
                        <section class="s_text_block container py-5">
                            <div class="row"><div class="col-lg-9 mx-auto">
                                <h1>Cancellation Policy</h1>
                                <p>This policy explains how to cancel a booking and any applicable charges.</p>
                                <h3>How to cancel</h3>
                                <p>Contact the dealer or use your account's booking page to request a
                                   cancellation. The booking status will be updated accordingly.</p>
                                <h3>Charges</h3>
                                <p>Cancellation charges (if any) depend on the timing of the request and are
                                   detailed by the dealer; the remainder of the deposit is refunded per the
                                   Refund Policy.</p>
                                <p><em>Replace this template with your dealership's official Cancellation
                                   Policy.</em></p>
                            </div></div>
                        </section>
                    </div>
                </t>
            </t>
        </field>
    </record>
    <record id="cancellation_policy_page" model="website.page">
        <field name="name">Cancellation Policy</field>
        <field name="view_id" ref="cancellation_policy_view"/>
        <field name="url">/cancellation-policy</field>
        <field name="is_published">True</field>
    </record>
</odoo>
