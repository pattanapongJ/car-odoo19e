<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         VERSIONED SHOWROOM HOME  (opt-in, non-destructive)
         A code-controlled, MULTI-MODEL home rendered from the backend
         "Home Layout" config (Master Data > Home Layout): an ordered list
         of sections, each optionally bound to a specific car model.
         Manage the whole home from the back office — no builder drag-and-drop.
         The oe_structure regions remain freely editable for marketing blocks.
         Set it as the site homepage via Website > Settings when ready.
         ================================================================ -->
    <record id="showroom_home_view" model="ir.ui.view">
        <field name="name">Showroom Home</field>
        <field name="type">qweb</field>
        <field name="key">bs_car_booking.showroom_home</field>
        <field name="arch" type="xml">
            <t t-name="bs_car_booking.showroom_home">
                <t t-call="website.layout">
                    <t t-set="title">Showroom</t>
                    <t t-set="bs_hero_overlay" t-value="True"/>
                    <div id="wrap" class="oe_structure_solo">

                        <!-- Editable marketing region (top) -->
                        <div class="oe_structure" id="oe_structure_showroom_top"/>

                        <!-- Backend-managed sections (each can target its own model) -->
                        <t t-set="home_blocks"
                           t-value="request.env['bs.car.home.block'].sudo().search([('active', '=', True)])"/>
                        <t t-foreach="home_blocks" t-as="block">
                            <section t-if="block.block_type == 'featured_hero'" class="s_bs_featured_model">
                                <t t-call="bs_car_booking.featured_model_content">
                                    <t t-set="featured_car" t-value="block.model_id"/>
                                </t>
                            </section>
                            <section t-elif="block.block_type == 'model_stage'" class="s_bs_model_stage">
                                <t t-call="bs_car_booking.model_stage_content">
                                    <t t-set="featured_car" t-value="block.model_id"/>
                                </t>
                            </section>
                            <section t-elif="block.block_type == 'color_studio'" class="s_bs_color_studio car_catalog_band">
                                <t t-call="bs_car_booking.color_studio_content">
                                    <t t-set="featured_car" t-value="block.model_id"/>
                                </t>
                            </section>
                            <section t-elif="block.block_type == 'heritage'" class="s_bs_heritage">
                                <t t-call="bs_car_booking.heritage_content"/>
                            </section>
                            <section t-elif="block.block_type == 'gallery'" class="s_bs_model_gallery">
                                <t t-call="bs_car_booking.model_gallery_content">
                                    <t t-set="featured_car" t-value="block.model_id"/>
                                </t>
                            </section>
                            <section t-elif="block.block_type == 'specs'"
                                     class="o_cc o_cc5 o_colored_level pt48 pb48">
                                <t t-call="bs_car_booking.model_specs_content">
                                    <t t-set="featured_car" t-value="block.model_id"/>
                                </t>
                            </section>
                            <section t-elif="block.block_type == 'highlights'" class="s_bs_highlights car_catalog_band">
                                <t t-call="bs_car_booking.highlights_content">
                                    <t t-set="featured_car" t-value="block.model_id"/>
                                </t>
                            </section>
                            <section t-elif="block.block_type == 'cabin_story'" class="s_bs_cabin_story">
                                <t t-call="bs_car_booking.cabin_story_content">
                                    <t t-set="featured_car" t-value="block.model_id"/>
                                </t>
                            </section>
                            <section t-elif="block.block_type == 'lineup'" class="car_catalog_band">
                                <div class="container">
                                    <div class="section_header_center">
                                        <span class="car_kicker car_kicker_dark">The lineup</span>
                                        <h2 class="section_title">Explore the range</h2>
                                    </div>
                                    <t t-set="models" t-value="request.env['bs.car.model'].sudo().search(
                                        [('website_published', '=', True), ('active', '=', True)], order='sequence, id')"/>
                                    <div class="car_grid">
                                        <a t-foreach="models" t-as="car" t-att-href="'/car/%s' % car.id"
                                           class="car_card">
                                            <div class="car_card_image">
                                                <img t-if="car.image"
                                                     t-att-src="'/web/image/bs.car.model/%s/image/600x375' % car.id"
                                                     t-att-alt="car.name" loading="lazy"/>
                                                <img t-else="" src="/web/static/img/placeholder.png"
                                                     t-att-alt="car.name" loading="lazy"/>
                                                <span class="car_card_tag" t-if="car.body_type"
                                                      t-esc="car.body_type.title()"/>
                                            </div>
                                            <div class="car_card_body">
                                                <span class="car_card_brand" t-esc="car.brand_id.name"/>
                                                <h3 class="car_card_title" t-esc="car.name"/>
                                                <div class="car_card_footer">
                                                    <div class="car_card_price">
                                                        <span>From</span>
                                                        <strong t-esc="car.base_price"
                                                                t-options="{'widget': 'monetary', 'display_currency': car.currency_id}"/>
                                                    </div>
                                                    <span class="car_card_arrow"><i class="fa fa-arrow-right"/></span>
                                                </div>
                                            </div>
                                        </a>
                                    </div>
                                </div>
                            </section>
                            <section t-elif="block.block_type == 'browse'" class="s_bs_browse car_catalog_band">
                                <t t-call="bs_car_booking.browse_tiles_content"/>
                            </section>
                            <section t-elif="block.block_type == 'stats'" class="s_bs_stats bs_stats_band">
                                <t t-call="bs_car_booking.stats_strip_content"/>
                            </section>
                            <section t-elif="block.block_type == 'arrivals'" class="s_bs_arrivals car_catalog_band">
                                <t t-call="bs_car_booking.latest_arrivals_content"/>
                            </section>
                            <section t-elif="block.block_type == 'offers'" class="s_bs_offers car_catalog_band">
                                <t t-call="bs_car_booking.offers_content">
                                    <t t-set="featured_car" t-value="False"/>
                                </t>
                            </section>
                            <section t-elif="block.block_type == 'stories'" class="s_bs_stories car_catalog_band">
                                <t t-call="bs_car_booking.stories_content">
                                    <t t-set="featured_car" t-value="block.model_id"/>
                                </t>
                            </section>
                            <section t-elif="block.block_type == 'finance'" class="s_bs_finance car_catalog_band">
                                <t t-call="bs_car_booking.finance_calculator_content">
                                    <t t-set="featured_car" t-value="block.model_id"/>
                                </t>
                            </section>
                            <section t-elif="block.block_type == 'dealers'" class="s_bs_dealers car_catalog_band">
                                <t t-call="bs_car_booking.dealer_locator_content"/>
                            </section>
                        </t>

                        <!-- Editable marketing region (bottom) -->
                        <div class="oe_structure" id="oe_structure_showroom_bottom"/>
                    </div>
                </t>
            </t>
        </field>
    </record>

    <record id="showroom_home_page" model="website.page">
        <field name="name">Showroom</field>
        <field name="view_id" ref="showroom_home_view"/>
        <field name="url">/showroom</field>
        <field name="is_published">True</field>
    </record>
</odoo>
