<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         PREMIUM CAR BOOKING WEBSITE TEMPLATES
         Image-led showroom experience for catalog and model detail pages.
         ================================================================ -->

    <!-- ── Car Listing Page ─────────────────────────────────────────── -->
    <template id="car_listing_page" name="Car Listing">
        <t t-call="website.layout">
            <t t-set="title">Model Lineup</t>
            <t t-set="bs_hero_overlay" t-value="True"/>
            <t t-set="hero_car" t-value="models[:1]"/>
            <t t-set="max_range" t-value="models and max(models.mapped('range_km') or [0]) or 0"/>
            <t t-set="active_filters" t-value="(active_brand_id and 1 or 0) + (active_body_type and 1 or 0)"/>

            <!-- ── Hero ───────────────────────────────────────────── -->
            <section class="bs_catalog_hero">
                <!-- Uploaded / direct .mp4/.webm → real looping background video.
                     Native <video muted autoplay playsinline> DOES autoplay on
                     mobile (unlike a YouTube/Vimeo iframe), so the hero plays on
                     every device. A portrait mobile clip is used when supplied. -->
                <t t-if="hero_car and hero_car.hero_media_type == 'video' and hero_car.hero_video_src">
                    <video class="bs_catalog_hero_img bs_hero_video"
                           autoplay="autoplay" muted="muted" loop="loop" playsinline="playsinline"
                           preload="metadata" disablepictureinpicture="disablepictureinpicture"
                           t-att-poster="hero_car.image and '/web/image/bs.car.model/%s/image/1920x1080' % hero_car.id or None">
                        <source t-att-src="hero_car.hero_video_src"/>
                    </video>
                </t>
                <!-- YouTube / Vimeo embed: desktop background only; the poster
                     image takes over on mobile (iframes can't background there). -->
                <t t-elif="hero_car and hero_car.hero_embed_url">
                    <div class="bs_hero_embed" aria-hidden="true">
                        <iframe t-att-src="hero_car.hero_embed_url"
                                title="Hero video" loading="eager"
                                allow="autoplay; fullscreen"
                                referrerpolicy="strict-origin-when-cross-origin"/>
                    </div>
                    <img t-if="hero_car.image" class="bs_catalog_hero_img bs_hero_poster"
                         t-att-src="'/web/image/bs.car.model/%s/image/1920x1080' % hero_car.id"
                         t-att-alt="hero_car.name"/>
                </t>
                <!-- Plain image hero. -->
                <t t-elif="hero_car and hero_car.image">
                    <img class="bs_catalog_hero_img"
                         t-att-src="'/web/image/bs.car.model/%s/image/1920x1080' % hero_car.id"
                         t-att-alt="hero_car.name"/>
                </t>
                <div t-else="" class="bs_catalog_hero_fallback"/>
                <div class="bs_catalog_hero_scrim"/>
                <div class="container bs_catalog_hero_content">
                    <div class="bs_catalog_hero_copy" data-bs-reveal="">
                        <span t-if="hero_car" class="car_kicker" t-esc="hero_car.brand_id.name"/>
                        <span t-else="" class="car_kicker">Model Lineup</span>
                        <h1 class="car_hero_title">The collection.</h1>
                        <p class="bs_catalog_hero_subtitle">
                            Every model. Every specification. One clear view of the range.
                        </p>
                        <div class="car_showroom_actions">
                            <a href="#car_catalog" class="btn btn-primary car_cta_btn">
                                Explore models <i class="fa fa-arrow-down"/>
                            </a>
                            <a t-if="hero_car" t-att-href="'/car/%s' % hero_car.id"
                               class="btn btn-outline-light car_ghost_btn">
                                View flagship <i class="fa fa-arrow-right"/>
                            </a>
                        </div>
                    </div>
                    <div class="bs_catalog_hero_metrics" data-bs-reveal="">
                        <div class="bs_hero_stat">
                            <strong t-esc="len(models)"/>
                            <span t-esc="len(models) == 1 and 'Model' or 'Models'"/>
                        </div>
                        <div class="bs_hero_stat" t-if="max_range">
                            <strong><t t-esc="max_range"/><small>km</small></strong>
                            <span>Max range</span>
                        </div>
                        <div class="bs_hero_stat">
                            <strong t-esc="len(brands)"/>
                            <span t-esc="len(brands) == 1 and 'Brand' or 'Brands'"/>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ── Catalog ─────────────────────────────────────────── -->
            <section id="car_catalog" class="bs_catalog_band">
                <div class="container">
                    <!-- header row -->
                    <div class="bs_catalog_header" data-bs-reveal="">
                        <div>
                            <span class="car_kicker car_kicker_dark">Model lineup</span>
                            <h2 class="section_title section_title_left">
                                <t t-esc="len(models)"/> model<t t-if="len(models) != 1">s</t> available
                            </h2>
                        </div>
                        <t t-if="active_filters">
                            <a href="/cars" class="bs_filter_clear">
                                <i class="fa fa-times"/> Clear filters
                            </a>
                        </t>
                    </div>

                    <!-- sticky filter wrapper -->
                    <div class="bs_filter_sticky" data-bs-filter-sticky="">
                        <!-- brand pills -->
                        <div class="bs_filter_bar" aria-label="Filter cars by brand">
                            <a t-att-href="'/cars'"
                               t-attf-class="bs_filter_pill {{ not active_brand_id and not active_body_type and 'is-active' or '' }}">
                                All
                            </a>
                            <t t-foreach="brands" t-as="brand">
                                <a t-att-href="'/cars?brand_id=%s' % brand.id"
                                   t-attf-class="bs_filter_pill {{ active_brand_id == brand.id and 'is-active' or '' }}">
                                    <t t-esc="brand.name"/>
                                </a>
                            </t>
                        </div>

                        <!-- body-type pills -->
                        <div t-if="body_types" class="bs_filter_bar bs_filter_bar_secondary" aria-label="Filter cars by body type">
                            <t t-foreach="body_types" t-as="bt">
                                <a t-att-href="active_body_type == bt[0] and '/cars' or '/cars?body_type=%s' % bt[0]"
                                   t-attf-class="bs_filter_pill bs_filter_pill_body {{ active_body_type == bt[0] and 'is-active' or '' }}">
                                    <i t-attf-class="fa fa-{{ {'suv':'truck','sedan':'car','coupe':'car','hatchback':'car','convertible':'car','pickup':'truck','van':'bus'}.get(bt[0], 'car') }}"/>
                                    <t t-esc="bt[1]"/>
                                </a>
                            </t>
                        </div>
                    </div>

                    <!-- car grid -->
                    <div class="bs_catalog_grid">
                        <t t-foreach="models" t-as="car">
                            <a t-att-href="'/car/%s' % car.id" class="bs_catalog_card" data-bs-reveal="">
                                <div class="bs_catalog_card_media">
                                    <t t-if="car.image">
                                        <img t-att-src="'/web/image/bs.car.model/%s/image/800x534' % car.id"
                                             t-att-alt="car.name" loading="lazy"/>
                                    </t>
                                    <t t-else="">
                                        <div class="bs_catalog_card_placeholder">
                                            <i class="fa fa-car"/>
                                        </div>
                                    </t>
                                    <span t-if="car.is_new_arrival" class="bs_card_badge bs_card_badge_new">New</span>
                                    <span t-if="car.body_type" class="bs_card_badge bs_card_badge_type" t-esc="car.body_type.title()"/>
                                    <div class="bs_catalog_card_overlay"/>
                                </div>
                                <div class="bs_catalog_card_body">
                                    <div class="bs_catalog_card_head">
                                        <span class="bs_card_brand" t-esc="car.brand_id.name"/>
                                    </div>
                                    <h3 class="bs_card_title" t-esc="car.name"/>
                                    <div class="bs_card_specs">
                                        <span t-if="car.range_km" class="bs_card_spec">
                                            <i class="fa fa-bolt"/>
                                            <strong t-esc="car.range_km"/><small>km</small>
                                        </span>
                                        <span t-if="car.acceleration" class="bs_card_spec">
                                            <i class="fa fa-tachometer"/>
                                            <strong t-esc="car.acceleration"/><small>s</small>
                                        </span>
                                        <span t-if="car.seats" class="bs_card_spec">
                                            <i class="fa fa-user"/>
                                            <strong t-esc="car.seats"/>
                                        </span>
                                    </div>
                                    <div class="bs_catalog_card_footer">
                                        <div class="bs_card_price">
                                            <span class="bs_card_price_label">From</span>
                                            <strong t-esc="car.base_price"
                                                    t-options="{'widget': 'monetary', 'display_currency': car.currency_id}"/>
                                        </div>
                                        <span class="bs_card_cta">
                                            Discover <i class="fa fa-arrow-right"/>
                                        </span>
                                    </div>
                                </div>
                            </a>
                        </t>
                    </div>

                    <div t-if="not models" class="bs_catalog_empty">
                        <i class="fa fa-car"/>
                        <h3>No models available</h3>
                        <p>Publish a car model in the backend to show it on this page.</p>
                    </div>
                </div>
            </section>
        </t>
    </template>

    <!-- ── Car Detail Page ──────────────────────────────────────────── -->
    <template id="car_detail_page" name="Car Detail">
        <t t-call="website.layout">
            <t t-set="title" t-value="car.name"/>
            <t t-set="bs_hero_overlay" t-value="True"/>
            <t t-set="additional_title" t-value="car.brand_id.name"/>

            <!-- SEO: Schema.org Vehicle structured data (rich results) -->
            <script type="application/ld+json" t-out="car.sudo()._website_jsonld()"/>

            <section class="car_detail_hero">
                <t t-call="bs_car_booking.hero_media">
                    <t t-set="hero_class" t-value="'car_detail_hero_img'"/>
                    <t t-set="fallback_class" t-value="'car_detail_hero_fallback'"/>
                    <t t-set="img_w" t-value="'1920x1080'"/>
                </t>
                <div class="car_detail_hero_overlay">
                    <div class="container car_detail_hero_content" data-bs-car-reveal="hero">
                        <span class="car_detail_brand" t-esc="car.brand_id.name"/>
                        <h1 class="car_detail_title" t-esc="car.name"/>
                        <div class="car_detail_price">
                            From
                            <strong t-esc="car.base_price"
                                    t-options="{'widget': 'monetary', 'display_currency': car.currency_id}"/>
                        </div>
                        <div class="car_detail_actions">
                            <a t-att-href="'/car/%s/book' % car.id" class="btn btn-primary car_cta_btn">
                                Configure <i class="fa fa-sliders"/>
                            </a>
                            <a href="#model_specs" class="btn btn-outline-light car_ghost_btn">
                                View Specs <i class="fa fa-arrow-down"/>
                            </a>
                        </div>
                    </div>
                </div>
            </section>

            <section id="model_specs" class="container car_quick_specs" data-bs-car-reveal="up">
                <t t-set="hl_specs" t-value="car.spec_ids.filtered('is_highlight')"/>
                <t t-if="hl_specs">
                    <!-- Data-driven hero highlights from the spec sheet -->
                    <div class="spec_item" t-foreach="hl_specs" t-as="sp">
                        <span class="spec_value" t-esc="sp.value"/>
                        <span class="spec_label"><t t-esc="sp.unit"/> <t t-esc="sp.name"/></span>
                    </div>
                </t>
                <t t-else="">
                    <!-- Fallback to model fields when no spec sheet is configured -->
                    <div class="spec_item" t-if="car.range_km">
                        <span class="spec_value" t-att-data-bs-count-to="car.range_km" t-esc="car.range_km"/>
                        <span class="spec_label">km Range</span>
                    </div>
                    <div class="spec_item" t-if="car.acceleration">
                        <span class="spec_value" t-esc="car.acceleration"/>
                        <span class="spec_label">s 0-100 km/h</span>
                    </div>
                    <div class="spec_item" t-if="car.top_speed">
                        <span class="spec_value" t-att-data-bs-count-to="car.top_speed" t-esc="car.top_speed"/>
                        <span class="spec_label">km/h Top Speed</span>
                    </div>
                    <div class="spec_item" t-if="car.seats">
                        <span class="spec_value" t-att-data-bs-count-to="car.seats" t-esc="car.seats"/>
                        <span class="spec_label">Seats</span>
                    </div>
                </t>
            </section>

            <!-- Full data-driven specification sheet -->
            <section t-if="car.spec_ids" id="full_specs" class="container car_spec_sheet_band" data-bs-car-reveal="up">
                <div class="section_header_center">
                    <span class="car_kicker car_kicker_dark">Specifications</span>
                    <h2 class="section_title"><t t-esc="car.name"/> spec sheet</h2>
                </div>
                <div class="car_spec_sheet">
                    <div class="car_spec_row" t-foreach="car.spec_ids" t-as="sp">
                        <span class="car_spec_k" t-esc="sp.name"/>
                        <span class="car_spec_v">
                            <t t-esc="sp.value"/>
                            <span class="car_spec_u" t-if="sp.unit" t-esc="sp.unit"/>
                        </span>
                    </div>
                </div>
            </section>

            <section class="car_detail_nav">
                <div class="container car_detail_nav_inner">
                    <span><t t-esc="car.brand_id.name"/> <t t-esc="car.name"/></span>
                    <div>
                        <a href="#variants" t-if="variants">Package</a>
                        <a href="#gallery" t-if="car.gallery_image_ids">Gallery</a>
                        <a href="#dealers" t-if="dealers">Dealers</a>
                        <a t-att-href="'/car/%s/book' % car.id" class="btn btn-primary btn-sm">
                            Reserve
                        </a>
                    </div>
                </div>
            </section>

            <section t-if="car.description or car.highlight_features" class="car_story_band">
                <div class="container car_story_grid">
                    <div t-if="car.description" class="car_description" data-bs-car-reveal="up">
                        <span class="car_kicker car_kicker_dark">Overview</span>
                        <t t-out="car.description"/>
                    </div>
                    <div t-if="car.highlight_features" class="car_features" data-bs-car-reveal="up">
                        <h2 class="section_title section_title_left">Key features</h2>
                        <div class="feature_list">
                            <t t-foreach="car.highlight_features.strip().split('\n')" t-as="feature">
                                <div class="feature_item" t-if="feature.strip()">
                                    <i class="fa fa-check-circle"/>
                                    <span t-esc="feature.strip()"/>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </section>

            <section id="variants" t-if="variants" class="container car_variants py-5">
                <div class="section_header_center" data-bs-car-reveal="up">
                    <span class="car_kicker car_kicker_dark">Standard Package</span>
                    <h2 class="section_title">Included booking package</h2>
                </div>
                <div class="variant_grid">
                    <t t-foreach="variants" t-as="variant">
                        <div class="variant_card" data-bs-car-reveal="up">
                            <h4 t-esc="variant.name"/>
                            <div class="variant_specs">
                                <span t-if="variant.range_km or car.range_km">
                                    <strong t-esc="variant.range_km or car.range_km"/> km
                                </span>
                                <span t-if="variant.acceleration or car.acceleration">
                                    <strong t-esc="variant.acceleration or car.acceleration"/>s
                                </span>
                            </div>
                            <div class="variant_price" t-esc="variant.price"
                                 t-options="{'widget': 'monetary', 'display_currency': car.currency_id}"/>
                            <div class="variant_delivery">
                                Est. delivery: <t t-esc="variant.estimated_delivery_days"/> days
                            </div>
                        </div>
                    </t>
                </div>
            </section>

            <section id="gallery" t-if="car.gallery_image_ids" class="car_gallery_band">
                <div class="container">
                    <div class="section_header_center" data-bs-car-reveal="up">
                        <span class="car_kicker">Gallery</span>
                        <h2 class="section_title section_title_light">Design in detail</h2>
                    </div>
                    <div class="gallery_grid bs_gallery">
                        <t t-foreach="car.gallery_image_ids" t-as="img">
                            <figure class="gallery_item" data-bs-car-reveal="up">
                                <img t-att-src="'/web/image/bs.car.model.image/%s/image/900x600' % img.id"
                                     t-att-data-bs-full="'/web/image/bs.car.model.image/%s/image' % img.id"
                                     t-att-alt="img.name or car.name" loading="lazy"/>
                                <figcaption t-if="img.name" t-esc="img.name"/>
                            </figure>
                        </t>
                    </div>
                </div>
            </section>

            <section id="dealers" t-if="dealers" class="container car_dealers py-5">
                <div class="section_header_center" data-bs-car-reveal="up">
                    <span class="car_kicker car_kicker_dark">Dealer network</span>
                    <h2 class="section_title">Choose where to continue.</h2>
                </div>
                <div class="dealer_grid">
                    <t t-foreach="dealers" t-as="dealer">
                        <div class="dealer_card" data-bs-car-reveal="up">
                            <t t-if="dealer.image">
                                <img t-att-src="'/web/image/bs.car.dealer/%s/image/600x400' % dealer.id"
                                     t-att-alt="dealer.name" loading="lazy"/>
                            </t>
                            <div class="dealer_card_body">
                                <h4 t-esc="dealer.name"/>
                                <div class="dealer_info">
                                    <div t-if="dealer.city">
                                        <i class="fa fa-map-marker"/> <t t-esc="dealer.city"/>
                                    </div>
                                    <div t-if="dealer.phone">
                                        <i class="fa fa-phone"/> <t t-esc="dealer.phone"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>
            </section>

            <!-- Active offers for this model (plus global offers) -->
            <section class="s_bs_offers car_catalog_band">
                <t t-call="bs_car_booking.offers_content">
                    <t t-set="featured_car" t-value="car"/>
                </t>
            </section>

            <section class="car_cta_section">
                <div class="container car_cta_inner" data-bs-car-reveal="up">
                    <div>
                        <span class="car_kicker">Booking deposit</span>
                        <h2>Reserve your <t t-esc="car.name"/>.</h2>
                        <p>
                            Secure the booking with a deposit of
                            <strong t-esc="car.deposit_amount"
                                    t-options="{'widget': 'monetary', 'display_currency': car.currency_id}"/>.
                        </p>
                    </div>
                    <a t-att-href="'/car/%s/book' % car.id" class="btn btn-primary btn-lg car_cta_btn">
                        Book Now <i class="fa fa-arrow-right"/>
                    </a>
                </div>
            </section>
        </t>
    </template>
</odoo>
