<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Car Model Form & Tree -->
    <record id="view_bs_car_model_tree" model="ir.ui.view">
        <field name="name">bs.car.model.tree</field>
        <field name="model">bs.car.model</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="brand_id"/>
                <field name="model_year" optional="hide"/>
                <field name="website_id" optional="hide"/>
                <field name="company_id" optional="hide"/>
                <field name="body_type"/>
                <field name="base_price" widget="monetary"/>
                <field name="deposit_amount" widget="monetary"/>
                <field name="variant_count"/>
                <field name="website_published"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_bs_car_model_form" model="ir.ui.view">
        <field name="name">bs.car.model.form</field>
        <field name="model">bs.car.model</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_generate_product" type="object" class="btn-primary"
                            string="Generate / Update Product"
                            confirm="This will create or refresh the configurable product and its options. Continue?"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_product" type="object" class="oe_stat_button"
                                icon="fa-car" invisible="not product_tmpl_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Product</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Model Name"/></h1>
                        <h3><field name="brand_id" placeholder="Brand"/></h3>
                    </div>
                    <field name="product_tmpl_id" invisible="1"/>
                    <notebook>
                        <page string="General">
                            <group>
                                <group>
                                    <field name="sequence"/>
                                    <field name="website_id"/>
                                    <field name="company_id"/>
                                    <field name="body_type"/>
                                    <field name="model_year"/>
                                    <field name="seats"/>
                                    <field name="website_published"/>
                                    <field name="website_featured"/>
                                    <field name="is_available"/>
                                    <field name="active"/>
                                </group>
                                <group>
                                    <field name="base_price" widget="monetary"/>
                                    <field name="deposit_amount" widget="monetary"/>
                                    <field name="currency_id" invisible="1"/>
                                    <field name="arrival_date"/>
                                    <field name="is_new_arrival"/>
                                </group>
                            </group>
                            <group string="Description">
                                <field name="description" widget="html"/>
                            </group>
                            <group string="Highlight Features">
                                <field name="highlight_features" widget="text" placeholder="One feature per line..."/>
                            </group>
                        </page>
                        <page string="Media Library">
                            <p class="text-muted">
                                Shared model media. The main image is used by listings, booking cards,
                                detail-page fallback/poster, and SEO previews. The gallery is used by the
                                car detail page.
                            </p>
                            <group string="Main Image">
                                <field name="image" widget="image"/>
                            </group>
                            <group string="Detail Hero Video (optional)">
                                <field name="hero_video_filename" invisible="1"/>
                                <field name="hero_video" widget="binary" filename="hero_video_filename"/>
                                <field name="hero_video_url" placeholder="https://cdn.example.com/hero.mp4"
                                       readonly="hero_video"/>
                                <span class="text-muted">
                                    Upload an .mp4/.webm or paste a direct video URL to play in the model
                                    hero areas. Use Home Showcase only for campaign-specific stage,
                                    highlight, and cabin story media.
                                </span>
                            </group>
                            <group string="Detail Gallery">
                                <field name="gallery_image_ids">
                                    <list editable="top">
                                        <field name="sequence" widget="handle"/>
                                        <field name="name"/>
                                        <field name="image" widget="image"/>
                                    </list>
                                </field>
                            </group>
                        </page>
                        <page string="Standard Package">
                            <p class="text-muted">
                                Define the default booking package for this model. If the business does
                                not sell multiple grades, keep one active line named <b>Standard</b>.
                                Exterior colours, interiors, wheels, and add-ons are maintained under
                                <b>Options &amp; Pricing</b>.
                            </p>
                            <field name="variant_ids" context="{'default_model_id': id}">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="price" widget="monetary"/>
                                    <field name="available_qty"/>
                                    <field name="website_published"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                        <page string="Options &amp; Pricing">
                            <p class="text-muted">
                                Configure selectable options (color, interior, wheels, add-ons) and
                                their extra price. Exterior Color and Interior option lines also drive the
                                website Colour Studio: set swatches, images, and available interiors on
                                those option records. Click <b>Generate / Update Product</b> after editing.
                            </p>
                            <field name="option_ids" context="{'default_model_id': id}">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="attribute_id" readonly="1" optional="show"/>
                                    <field name="value_id"
                                           domain="[('attribute_id.create_variant', '=', 'no_variant')]"
                                           options="{'no_create_edit': True}"/>
                                    <field name="price_extra" widget="monetary"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="image" widget="image" width="100px" height="100px"/>
                                    <field name="swatch_color" optional="show"/>
                                    <field name="swatch_color_2" optional="hide"/>
                                    <field name="image_alt" optional="show"/>
                                    <field name="website_published" widget="boolean_toggle" optional="show"/>
                                    <field name="attribute_name" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Specifications">
                            <p class="text-muted">
                                Technical spec sheet shown on the website detail page and home sections.
                                Range, 0-100 km/h, and top speed are synced from these rows into website
                                filters and model cards. Mark a few rows as <b>Hero Highlight</b>.
                            </p>
                            <field name="spec_ids" context="{'default_model_id': id}">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="value"/>
                                    <field name="unit"/>
                                    <field name="is_highlight"/>
                                </list>
                            </field>
                        </page>
                        <page string="Freebies">
                            <p class="text-muted">
                                Complimentary items / gifts shown in the booking <b>Review &amp; Confirm</b>
                                pop-up. Pick an <b>Icon</b> from the list; the optional Note is shown in
                                grey after the item.
                            </p>
                            <field name="freebie_ids" context="{'default_model_id': id}">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="note"/>
                                    <field name="icon"/>
                                    <field name="website_published" optional="show"/>
                                </list>
                            </field>
                        </page>
                        <page string="Home Showcase">
                            <p class="text-muted">
                                Curate editorial home-page sections for this model. Do not duplicate shared
                                product media here unless the image needs section-specific copy, ordering,
                                gallery thumbnails, or CTA behavior. Colour Studio is driven by
                                <b>Options &amp; Pricing</b>.
                            </p>
                            <separator string="Model Stage — campaign slides with copy/CTA"/>
                            <field name="stage_item_ids" nolabel="1">
                                    <list>
                                        <field name="sequence" widget="handle"/>
                                        <field name="name" string="Caption"/>
                                        <field name="subtitle" optional="show"/>
                                        <field name="image" widget="image"/>
                                        <field name="website_published" widget="boolean_toggle"/>
                                    </list>
                                    <form string="Model Stage Slide">
                                        <sheet>
                                            <div class="oe_title">
                                                <label for="name"/>
                                                <h1><field name="name" placeholder="Slide caption"/></h1>
                                                <h3><field name="subtitle" placeholder="Optional supporting line"/></h3>
                                            </div>
                                            <group>
                                                <group string="Placement">
                                                    <field name="sequence"/>
                                                    <field name="item_type" invisible="1"/>
                                                    <field name="website_published"/>
                                                    <field name="active"/>
                                                </group>
                                                <group string="Media">
                                                    <field name="image" widget="image" class="oe_avatar"/>
                                                    <field name="image_alt"/>
                                                </group>
                                            </group>
                                            <notebook>
                                                <page string="Content">
                                                    <field name="description" widget="html" nolabel="1"/>
                                                </page>
                                                <page string="CTA">
                                                    <group>
                                                        <field name="cta_label"/>
                                                        <field name="cta_url"/>
                                                    </group>
                                                </page>
                                            </notebook>
                                        </sheet>
                                    </form>
                            </field>
                            <separator string="Highlights — editorial feature cards"/>
                            <field name="highlight_item_ids" nolabel="1">
                                    <list>
                                        <field name="sequence" widget="handle"/>
                                        <field name="name" string="Title"/>
                                        <field name="subtitle" optional="show"/>
                                        <field name="image" widget="image"/>
                                        <field name="website_published" widget="boolean_toggle"/>
                                    </list>
                                    <form string="Highlight Card">
                                        <sheet>
                                            <div class="oe_title">
                                                <label for="name"/>
                                                <h1><field name="name" placeholder="Welcome Light, Executive Cabin..."/></h1>
                                                <h3><field name="subtitle" placeholder="Short kicker / supporting line"/></h3>
                                            </div>
                                            <group>
                                                <group string="Placement">
                                                    <field name="sequence"/>
                                                    <field name="item_type" invisible="1"/>
                                                    <field name="website_published"/>
                                                    <field name="active"/>
                                                </group>
                                                <group string="Card Image">
                                                    <field name="image" widget="image" class="oe_avatar"/>
                                                    <field name="image_alt"/>
                                                </group>
                                            </group>
                                            <notebook>
                                                <page string="Content">
                                                    <field name="description" widget="html" nolabel="1"/>
                                                </page>
                                                <page string="Gallery">
                                                    <p class="text-muted">
                                                        Add close-up, wide, or alternate images for this highlight.
                                                        They appear as thumbnails in the lightbox.
                                                    </p>
                                                    <field name="highlight_image_ids" nolabel="1">
                                                        <list>
                                                            <field name="sequence" widget="handle"/>
                                                            <field name="image" widget="image"/>
                                                            <field name="name"/>
                                                            <field name="image_alt" optional="show"/>
                                                        </list>
                                                        <form string="Highlight Image">
                                                            <sheet>
                                                                <div class="oe_title">
                                                                    <label for="name"/>
                                                                    <h1><field name="name" placeholder="Close-up or wide view"/></h1>
                                                                </div>
                                                                <group>
                                                                    <group>
                                                                        <field name="sequence"/>
                                                                        <field name="image_alt"/>
                                                                    </group>
                                                                    <group string="Image">
                                                                        <field name="image" widget="image" class="oe_avatar"/>
                                                                    </group>
                                                                </group>
                                                            </sheet>
                                                        </form>
                                                    </field>
                                                </page>
                                                <page string="CTA">
                                                    <group>
                                                        <field name="cta_label"/>
                                                        <field name="cta_url"/>
                                                    </group>
                                                </page>
                                            </notebook>
                                        </sheet>
                                    </form>
                            </field>
                            <separator string="Cabin Story — editorial wide band"/>
                            <field name="cabin_item_ids" nolabel="1">
                                    <list>
                                        <field name="sequence" widget="handle"/>
                                        <field name="name" string="Headline"/>
                                        <field name="subtitle" optional="show"/>
                                        <field name="image" widget="image"/>
                                        <field name="website_published" widget="boolean_toggle"/>
                                    </list>
                                    <form string="Cabin Story">
                                        <sheet>
                                            <div class="oe_title">
                                                <label for="name"/>
                                                <h1><field name="name" placeholder="Cabin story headline"/></h1>
                                                <h3><field name="subtitle" placeholder="Short kicker / supporting line"/></h3>
                                            </div>
                                            <group>
                                                <group string="Placement">
                                                    <field name="sequence"/>
                                                    <field name="item_type" invisible="1"/>
                                                    <field name="website_published"/>
                                                    <field name="active"/>
                                                </group>
                                                <group string="Wide Image">
                                                    <field name="image" widget="image" class="oe_avatar"/>
                                                    <field name="image_alt"/>
                                                </group>
                                            </group>
                                            <notebook>
                                                <page string="Content">
                                                    <field name="description" widget="html" nolabel="1"/>
                                                </page>
                                                <page string="CTA">
                                                    <group>
                                                        <field name="cta_label"/>
                                                        <field name="cta_url"/>
                                                    </group>
                                                </page>
                                            </notebook>
                                        </sheet>
                                    </form>
                            </field>
                        </page>
                        <page string="News">
                            <p class="text-muted">
                                News / editorial cards for the home "News" section. Leave an article's
                                model empty to make it brand-wide; set it here to tie the article to this model.
                            </p>
                            <field name="story_ids" context="{'default_model_id': id}">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name" string="Headline"/>
                                    <field name="location" optional="show"/>
                                    <field name="publish_date"/>
                                    <field name="subtitle" optional="hide"/>
                                    <field name="image" widget="image"/>
                                    <field name="website_published" widget="boolean_toggle"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_bs_car_model_search" model="ir.ui.view">
        <field name="name">bs.car.model.search</field>
        <field name="model">bs.car.model</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="brand_id"/>
                <filter name="published" string="Published" domain="[('website_published', '=', True)]"/>
                <filter name="active" string="Active" domain="[('active', '=', True)]"/>
                <group>
                    <filter name="sedan" string="Sedan" domain="[('body_type', '=', 'sedan')]"/>
                    <filter name="suv" string="SUV" domain="[('body_type', '=', 'suv')]"/>
                    <filter name="coupe" string="Coupe" domain="[('body_type', '=', 'coupe')]"/>
                    <filter name="hatchback" string="Hatchback" domain="[('body_type', '=', 'hatchback')]"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Media kanban: visual overview with image + featured/video badges -->
    <record id="view_bs_car_model_kanban" model="ir.ui.view">
        <field name="name">bs.car.model.kanban</field>
        <field name="model">bs.car.model</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="currency_id"/>
                <field name="model_year"/>
                <field name="website_published"/>
                <field name="website_featured"/>
                <field name="has_hero_video"/>
                <templates>
                    <t t-name="card">
                        <div class="ratio ratio-16x9 mb-2">
                            <img t-attf-src="/web/image/bs.car.model/#{record.id.raw_value}/image/480x300"
                                 style="width:100%;height:100%;object-fit:cover;border-radius:4px;" alt="model"/>
                        </div>
                        <div class="fw-bold fs-6">
                            <field name="name"/>
                            <span t-if="record.model_year.raw_value" class="text-muted">(<field name="model_year"/>)</span>
                        </div>
                        <field name="brand_id" class="text-muted"/>
                        <div class="mt-1"><field name="base_price" widget="monetary"/></div>
                        <div class="mt-1">
                            <span t-if="record.website_featured.raw_value" class="badge text-bg-warning">Featured</span>
                            <span t-if="record.has_hero_video.raw_value" class="badge text-bg-info">Video</span>
                            <span t-if="!record.website_published.raw_value" class="badge text-bg-secondary">Unpublished</span>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_bs_car_model" model="ir.actions.act_window">
        <field name="name">Car Models</field>
        <field name="res_model">bs.car.model</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="view_id" ref="view_bs_car_model_kanban"/>
    </record>
</odoo>
