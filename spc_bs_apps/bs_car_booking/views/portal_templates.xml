<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         MY ACCOUNT — add a "Car Bookings" card to the portal home
         ================================================================ -->
    <!-- priority 4 (account/sale use 30): applied first, so the business's
         primary object — the booking — is the FIRST card on /my/home. -->
    <template id="portal_my_home_booking" name="Portal My Home : Car Bookings"
              inherit_id="portal.portal_my_home" priority="4" customize_show="True">
        <!-- Enable the client documents category (async counter shows/hides the card). -->
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <t t-set="portal_client_category_enable" t-value="True"/>
        </xpath>
        <div id="portal_client_category" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Car Bookings</t>
                <t t-set="url" t-value="'/my/bookings'"/>
                <t t-set="text">Track your reservations &amp; deposits</t>
                <t t-set="placeholder_count" t-value="'booking_count'"/>
            </t>
        </div>
    </template>

    <!-- ================================================================
         MY BOOKINGS — list
         ================================================================ -->
    <template id="portal_my_bookings" name="My Car Bookings">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Car Bookings</t>
            </t>
            <t t-if="not bookings">
                <div class="alert alert-info">
                    You have no car bookings yet. <a href="/cars">Explore our cars</a>.
                </div>
            </t>
            <t t-if="bookings" t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>Reference</th>
                        <th>Car</th>
                        <th>Dealer</th>
                        <th class="text-end">Deposit</th>
                        <th class="text-center">Status</th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="bookings" t-as="booking">
                        <td><a t-att-href="booking.get_portal_url()"><span t-field="booking.name"/></a></td>
                        <td><span t-field="booking.model_id.name"/></td>
                        <td><span t-field="booking.dealer_id.name"/></td>
                        <td class="text-end">
                            <span t-field="booking.deposit_paid"
                                  t-options="{'widget': 'monetary', 'display_currency': booking.currency_id}"/>
                        </td>
                        <td class="text-center">
                            <span t-attf-class="badge rounded-pill #{booking.state in ('confirmed','in_production','ready_delivery','delivered') and 'text-bg-success' or booking.state == 'cancelled' and 'text-bg-danger' or booking.state == 'expired' and 'text-bg-secondary' or 'text-bg-warning'}"
                                  t-esc="booking.state_label"/>
                        </td>
                    </tr>
                </tbody>
            </t>
        </t>
    </template>

    <!-- ================================================================
         MY BOOKING — detail
         ================================================================ -->
    <template id="portal_my_booking" name="My Car Booking">
        <t t-call="portal.portal_layout">
            <t t-set="o_portal_fullwidth_alert" t-value="None"/>

            <div class="o_portal_my_booking">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3">
                    <h3 class="mb-0">Booking <span t-field="booking.name"/></h3>
                    <span t-attf-class="badge rounded-pill fs-6 #{booking.state in ('confirmed','in_production','ready_delivery','delivered') and 'text-bg-success' or booking.state == 'cancelled' and 'text-bg-danger' or booking.state == 'expired' and 'text-bg-secondary' or 'text-bg-warning'}"
                          t-esc="booking.state_label"/>
                </div>

                <!-- Step timeline removed by business request (2026-06-11):
                     the status pill next to the title already carries the
                     state; the delivery date moved into the Summary card. -->

                <div class="row">
                    <div class="col-lg-7">
                        <div class="card mb-4">
                            <div class="card-header"><strong>Your Car</strong></div>
                            <div class="card-body">
                                <div class="d-flex gap-3">
                                    <img t-if="booking.model_id.image"
                                         t-attf-src="/web/image/bs.car.model/{{ booking.model_id.id }}/image/280x180"
                                         class="rounded" style="width:140px;height:90px;object-fit:cover"/>
                                    <div>
                                        <h5 class="mb-1">
                                            <span t-field="booking.model_id.brand_id.name"/>
                                            <span t-field="booking.model_id.name"/>
                                        </h5>
                                        <div class="text-muted" t-field="booking.config_summary"/>
                                        <div t-if="booking.dealer_id" class="mt-2">
                                            <i class="fa fa-map-marker"/> <span t-field="booking.dealer_id.name"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Invoices -->
                        <div class="card mb-4" t-if="booking.invoice_ids">
                            <div class="card-header"><strong>Deposit Invoices</strong></div>
                            <div class="card-body p-0">
                                <table class="table mb-0">
                                    <tbody>
                                        <tr t-foreach="booking.invoice_ids" t-as="inv">
                                            <td><a t-att-href="inv.get_portal_url()" t-field="inv.name"/></td>
                                            <td class="text-end">
                                                <span t-field="inv.amount_total"
                                                      t-options="{'widget': 'monetary', 'display_currency': inv.currency_id}"/>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge text-bg-light" t-field="inv.payment_state"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Payments / transactions -->
                        <div class="card mb-4" t-if="booking.transaction_ids">
                            <div class="card-header"><strong>Payments</strong></div>
                            <div class="card-body p-0">
                                <table class="table mb-0">
                                    <tbody>
                                        <tr t-foreach="booking.transaction_ids" t-as="tx">
                                            <td><span t-field="tx.reference"/></td>
                                            <td><span t-field="tx.provider_id.name"/></td>
                                            <td class="text-end">
                                                <span t-field="tx.amount"
                                                      t-options="{'widget': 'monetary', 'display_currency': tx.currency_id}"/>
                                            </td>
                                            <td class="text-center"><span class="badge text-bg-light" t-field="tx.state"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-5">
                        <div class="card mb-4">
                            <div class="card-header"><strong>Summary</strong></div>
                            <div class="card-body">
                                <div class="d-flex justify-content-between py-1">
                                    <span class="text-muted">Order Total</span>
                                    <span t-field="booking.amount_total"
                                          t-options="{'widget': 'monetary', 'display_currency': booking.currency_id}"/>
                                </div>
                                <div class="d-flex justify-content-between py-1">
                                    <span class="text-muted">Deposit Paid</span>
                                    <span t-field="booking.deposit_paid"
                                          t-options="{'widget': 'monetary', 'display_currency': booking.currency_id}"/>
                                </div>
                                <div class="d-flex justify-content-between py-1" t-if="booking.sale_order_id">
                                    <span class="text-muted">Sale Order</span>
                                    <a t-att-href="booking.sale_order_id.get_portal_url()" t-field="booking.sale_order_id.name"/>
                                </div>
                                <!-- "When do I get my car" — moved here from the
                                     removed step timeline. -->
                                <div t-if="booking.state == 'delivered' and booking.actual_delivery_date"
                                     class="d-flex justify-content-between py-1">
                                    <span class="text-muted">Delivered On</span>
                                    <strong t-field="booking.actual_delivery_date"/>
                                </div>
                                <div t-elif="booking.estimated_delivery_date and booking.state in ('confirmed', 'in_production', 'ready_delivery')"
                                     class="d-flex justify-content-between py-1">
                                    <span class="text-muted">Estimated Delivery</span>
                                    <strong t-field="booking.estimated_delivery_date"/>
                                </div>
                                <hr/>
                                <a t-if="booking.state not in ('confirmed','in_production','ready_delivery','delivered','cancelled','expired')"
                                   t-att-href="'/booking/%s/payment?access_token=%s' % (booking.id, access_token)"
                                   class="btn btn-success w-100">
                                    <i class="fa fa-credit-card"/> Pay Deposit
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ================================================================
         PAYMENT STATUS — override for car booking context
         ================================================================ -->

    <!-- 1/2: Hide the "Skip" link for car-booking deposits.
         The skip link lets users jump to the landing route before
         post-processing completes (invoice creation, booking state sync).
         For car bookings we block this entirely — the JS poll must finish. -->
    <template id="payment_state_header_bs_car" name="Payment State Header : No Skip for Car Booking"
              inherit_id="payment.state_header">
        <xpath expr="//a[hasclass('alert-link') and hasclass('ms-auto')]" position="attributes">
            <attribute name="t-if">is_processing and not tx.booking_id</attribute>
        </xpath>
    </template>

    <!-- 2/2: Replace "Reference" (e.g. S00064) with booking name. -->
    <template id="payment_status_bs_car" name="Payment Status : Car Booking"
              inherit_id="payment.payment_status">
        <xpath expr="//t[@t-call='payment.summary_item'][2]" position="replace">
            <t t-if="tx.booking_id" t-call="payment.summary_item">
                <t t-set="name" t-value="'booking'"/>
                <t t-set="label">Booking</t>
                <t t-set="value" t-value="tx.booking_id.name"/>
                <t t-set="include_separator" t-value="True"/>
            </t>
            <t t-else="" t-call="payment.summary_item">
                <t t-set="name" t-value="'reference'"/>
                <t t-set="label">Reference</t>
                <t t-set="value" t-value="tx.reference"/>
                <t t-set="include_separator" t-value="True"/>
            </t>
        </xpath>
    </template>

    <!-- Business request (2026-06-12): no public message thread on customer
         invoices/orders — dealer communication goes through the call center /
         sales rep, not an unmonitored portal chat. -->
    <template id="portal_invoice_page_no_chatter" inherit_id="account.portal_invoice_page"
              name="Invoice Portal: hide communication history">
        <xpath expr="//div[@id='invoice_communication']" position="replace"/>
    </template>

    <template id="sale_order_portal_no_chatter" inherit_id="sale.sale_order_portal_template"
              name="Sale Order Portal: hide communication history">
        <xpath expr="//div[@id='sale_order_communication']" position="replace"/>
    </template>

    <!-- Car customers are never the dealer's suppliers: the vendor "Our
         Invoices" (bills) card only confuses next to "Your Invoices". -->
    <template id="portal_my_home_invoice_no_bills" inherit_id="account.portal_my_home_invoice"
              name="Portal Home: hide the vendor bills card">
        <xpath expr="//t[@t-set='portal_vendor_category_enable']" position="replace"/>
        <xpath expr="//div[@id='portal_vendor_category']" position="replace"/>
    </template>

</odoo>
