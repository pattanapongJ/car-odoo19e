<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         OTP VERIFICATION PAGE  (Step 2)
         ================================================================ -->
    <template id="otp_verification_page" name="OTP Verification">
        <t t-call="website.layout">
            <t t-set="title">Verify Your Phone</t>
            <section class="otp_section">
                <div class="container">
                    <div class="otp_card"
                         t-att-data-booking-id="booking.id"
                         t-att-data-access-token="access_token"
                         t-att-data-otp-expiry="otp_expires_in"
                         t-att-data-otp-resend="otp_resend_in">
                        <t t-call="bs_car_booking.booking_progress">
                            <t t-set="active_step" t-value="2"/>
                        </t>
                        <t t-set="is_email_otp" t-value="otp_channel == 'email'"/>
                        <div class="otp_icon">
                            <i t-attf-class="fa fa-{{ is_email_otp and 'envelope-o' or 'mobile-phone' }} fa-3x"/>
                        </div>
                        <h2 class="otp_title" t-esc="is_email_otp and 'Verify Your Email' or 'Verify Your Phone Number'"/>
                        <p class="otp_description">
                            We've sent a 6-digit verification code to
                            <strong t-esc="otp_destination or booking.customer_phone"/>
                        </p>
                        <p t-if="is_email_otp" class="otp_spam_hint text-muted">
                            Didn't receive it? Check your spam folder.
                        </p>
                        <div class="otp_form">
                            <div class="otp_input_group">
                                <t t-foreach="range(6)" t-as="i">
                                    <input type="text" class="otp_digit" maxlength="1"
                                           t-att-data-index="i" inputmode="numeric" pattern="[0-9]"/>
                                </t>
                            </div>
                            <div class="otp_timer">
                                <div class="bs_track_timer_row">
                                    <button id="otp_resend_btn" class="bs_track_resend_btn" disabled="disabled">
                                        <i class="fa fa-refresh"/>
                                        <span id="otp_resend_label"
                                              t-esc="(otp_expires_in &gt; 0) and ('Resend in %02d:%02d' % divmod(otp_expires_in, 60)) or 'Resend code'"/>
                                    </button>
                                </div>
                            </div>
                            <div class="otp_error d-none"><div class="alert alert-danger" id="otp_error_msg"/></div>
                            <div class="otp_success d-none"><div class="alert alert-success" id="otp_success_msg"/></div>
                            <div class="otp_actions">
                                <button id="otp_verify_btn" class="btn btn-primary btn-lg otp_verify_btn">
                                    <i class="fa fa-check"/> Verify
                                </button>
                                <!-- Customer-choice websites can reroute the code to the
                                     other channel (flag only; destination stays the
                                     booking's own phone/email). -->
                                <button t-if="otp_switch_channel" id="otp_switch_btn"
                                        class="btn btn-link otp_switch_btn"
                                        t-att-data-channel="otp_switch_channel">
                                    <t t-if="otp_switch_channel == 'email'">
                                        <i class="fa fa-envelope-o"/> Send to my email instead
                                    </t>
                                    <t t-else="">
                                        <i class="fa fa-mobile-phone"/> Send by SMS instead
                                    </t>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </t>
    </template>

    <!-- ================================================================
         CUSTOMER INFO PAGE  (Step 3)
         ================================================================ -->
    <template id="booking_info_page" name="Customer Information">
        <t t-call="website.layout">
            <t t-set="title">Your Details</t>
            <section class="info_section">
                <div class="container">
                    <div class="info_card">
                        <t t-call="bs_car_booking.booking_progress">
                            <t t-set="active_step" t-value="3"/>
                        </t>
                        <h2 class="info_title">Your Details</h2>
                        <p class="text-muted">Almost there — tell us who the booking is for.</p>
                        <div t-if="account_partner and account_partner.name" class="info_account_prefill mb-3">
                            <button type="button" class="btn btn-outline-secondary btn-sm" id="info_use_my_details"
                                    t-att-data-name="account_partner.name or ''"
                                    t-att-data-email="account_partner.email or ''"
                                    t-att-data-street="account_partner.street or ''">
                                <i class="fa fa-user"/> Use my account details
                                (<t t-esc="account_partner.name"/>)
                            </button>
                        </div>
                        <form id="bs_info_form" class="info_form"
                              t-att-data-booking-id="booking.id"
                              t-att-data-access-token="access_token"
                              t-att-data-max-mb="max_doc_mb">
                            <!-- Customer type -->
                            <div class="info_type_toggle mb-4">
                                <label class="form-label d-block">This booking is for *</label>
                                <div class="btn-group" role="group" aria-label="Customer type">
                                    <input type="radio" class="btn-check" name="customer_type" id="ct_individual"
                                           value="individual" t-att-checked="booking.customer_type != 'company' or None"/>
                                    <label class="btn btn-outline-primary" for="ct_individual">
                                        <i class="fa fa-user me-1"/> Individual
                                    </label>
                                    <input type="radio" class="btn-check" name="customer_type" id="ct_company"
                                           value="company" t-att-checked="booking.customer_type == 'company' or None"/>
                                    <label class="btn btn-outline-primary" for="ct_company">
                                        <i class="fa fa-building me-1"/> Company
                                    </label>
                                </div>
                            </div>

                            <!-- Person name: common to both types. Individuals give their
                                 own full name; companies give the authorised contact person.
                                 Stored in customer_name for both (contact_person was merged in). -->
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">
                                        <span data-type-group="individual">Full Name *</span>
                                        <span data-type-group="company" class="d-none">Contact Person *</span>
                                    </label>
                                    <input type="text" name="customer_name" class="form-control form-control-lg thai-input-only"
                                           t-att-value="booking.customer_name or ''" placeholder="Your full name"/>
                                </div>
                                <!-- Individual-only: NRC / ID -->
                                <div class="col-md-6 mb-3" data-type-group="individual">
                                    <label class="form-label">NRC / ID Number *</label>
                                    <input type="text" name="customer_nrc" class="form-control form-control-lg"
                                           t-att-value="booking.customer_nrc or ''" placeholder="ID / NRC"/>
                                </div>
                            </div>

                            <!-- Company-only fields -->
                            <div data-type-group="company" class="d-none">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Company Name *</label>
                                        <!-- Thai tax invoices need the branch designation next to the
                                             registered name (Head Office / branch no.) — the example
                                             nudges customers to include it. -->
                                        <input type="text" name="company_name" class="form-control form-control-lg thai-text-only"
                                               t-att-value="booking.company_name or ''"
                                               placeholder="e.g. Test Company Co., Ltd. (Head Office)"/>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Tax ID *</label>
                                        <input type="text" name="tax_id" class="form-control form-control-lg"
                                               t-att-value="booking.tax_id or ''" placeholder="VAT / Tax ID (on invoice)"/>
                                    </div>
                                </div>
                            </div>

                            <!-- Common -->
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Email</label>
                                    <input type="email" name="customer_email" class="form-control form-control-lg"
                                           t-att-value="booking.customer_email or ''" disabled="disabled"/>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Phone</label>
                                    <input type="tel" class="form-control form-control-lg"
                                           t-att-value="booking.customer_phone or ''" disabled="disabled"/>
                                </div>
                            </div>
                            <div class="mb-3">
                                <!-- Shared field, per-type label: individuals must give the
                                     address as printed on the ID card (matches the uploaded
                                     National ID document); companies their business address. -->
                                <label class="form-label">
                                    <span data-type-group="individual">Address on National ID Card</span>
                                    <span data-type-group="company" class="d-none">Address</span>
                                </label>
                                <textarea name="customer_address" class="form-control thai-text-only" rows="2"
                                          placeholder="(optional)"><t t-esc="booking.customer_address or ''"/></textarea>
                            </div>

                            <!-- Documents (the JS shows the ones for the selected type) -->
                            <t t-if="doc_types">
                                <h5 class="info_subhead">Documents</h5>
                                <p class="text-muted small mb-2">
                                    Accepted: PDF, JPG, PNG · max <t t-esc="max_doc_mb"/> MB per file.
                                </p>
                                <div class="row">
                                    <t t-foreach="doc_types" t-as="dt">
                                        <t t-set="dt_uploaded" t-value="dt.id in uploaded_doc_type_ids"/>
                                        <div t-attf-class="col-md-6 mb-3 info_doc_field #{dt_uploaded and 'is-uploaded' or ''}"
                                             t-att-data-applies-to="dt.applies_to"
                                             t-att-data-required="dt.required and '1' or '0'"
                                             t-att-data-uploaded="dt_uploaded and '1' or '0'">
                                            <label class="form-label">
                                                <t t-esc="dt.name"/><t t-if="dt.required"> *</t>
                                            </label>
                                            <!-- Already uploaded (e.g. after pressing Back): keep it, allow replace. -->
                                            <div t-if="dt_uploaded" class="info_doc_uploaded text-success small mb-1">
                                                <i class="fa fa-check-circle me-1"/>Uploaded — choose a new file to replace.
                                            </div>
                                            <div class="input-group">
                                                <input type="file" class="form-control info_doc_input"
                                                       t-att-data-doc-type-id="dt.id"
                                                       accept=".pdf,.jpg,.jpeg,.png,.webp"/>
                                                <button type="button" class="btn btn-outline-secondary info_doc_clear d-none"
                                                        title="Remove file" aria-label="Remove file">
                                                    <i class="fa fa-times"/>
                                                </button>
                                            </div>
                                            <small t-if="dt.help_text" class="text-muted d-block" t-esc="dt.help_text"/>
                                        </div>
                                    </t>
                                </div>
                            </t>

                            <!-- Agreements -->
                            <t t-if="agreements">
                                <div class="info_agreements mb-3">
                                    <div t-foreach="agreements" t-as="ag"
                                         class="form-check info_agreement"
                                         t-att-data-applies-to="ag.applies_to"
                                         t-att-data-required="ag.required and '1' or '0'">
                                        <input type="checkbox" class="form-check-input info_agree_check"
                                               t-attf-id="agree_{{ ag.id }}" t-att-data-agreement-id="ag.id"
                                               t-att-checked="ag.id in accepted_agreement_ids or None"/>
                                        <label class="form-check-label" t-attf-for="agree_{{ ag.id }}">
                                            <t t-esc="ag.cta_label"/>
                                        </label>
                                        <!-- Policy name itself is the link (opens in a new tab; sits
                                             outside the label so it doesn't toggle the checkbox). -->
                                        <a t-if="ag.page_url" class="bs_policy_link" t-att-href="ag.page_url"
                                           target="_blank" rel="noopener" t-esc="ag.name"/>
                                        <span t-else="" class="bs_policy_name" t-esc="ag.name"/>
                                    </div>
                                </div>
                            </t>

                            <div class="text-center">
                                <button type="submit" class="btn btn-primary btn-lg info_submit_btn" disabled="disabled">
                                    Review &amp; Confirm <i class="fa fa-arrow-right"/>
                                </button>
                                <div class="info_submit_hint text-muted small mt-2">
                                    <i class="fa fa-lock me-1"/>Complete the required details, documents and agreements to continue.
                                </div>
                                <div class="alert alert-danger mt-3 d-none" id="info_error"/>
                            </div>

                            <!-- ============================================================
                                 REVIEW CONFIRMATION MODAL
                                 Shown after the form validates and before the deposit step.
                                 Booking details are server-rendered; customer info and the
                                 attached documents are populated live by customer_info.js.
                                 ============================================================ -->
                            <t t-set="ext_color" t-value="booking._get_review_color('bs_car_booking.attr_color')"/>
                            <t t-set="int_color" t-value="booking._get_review_color('bs_car_booking.attr_interior')"/>
                            <div class="bs_review_overlay d-none" data-review-modal="" role="dialog"
                                 aria-modal="true" aria-labelledby="bs_review_title">
                                <div class="bs_review_modal">
                                    <div class="bs_review_header">
                                        <div class="bs_review_header_titles">
                                            <i class="fa fa-clipboard"/>
                                            <div>
                                                <p class="bs_review_title" id="bs_review_title">ตรวจสอบข้อมูลก่อนชำระเงิน</p>
                                                <p class="bs_review_subtitle">กรุณาตรวจสอบให้ครบถ้วนก่อนกดยืนยัน</p>
                                            </div>
                                        </div>
                                        <span class="bs_review_badge bs_review_badge_warn">รอยืนยัน</span>
                                    </div>

                                    <div class="bs_review_body">
                                        <!-- 1. ข้อมูลการจอง (server-rendered) -->
                                        <div class="bs_review_section">
                                            <div class="bs_review_section_head" data-review-toggle="">
                                                <span><i class="fa fa-file-text-o"/>ข้อมูลการจอง</span>
                                                <i class="fa fa-chevron-down bs_review_chevron"/>
                                            </div>
                                            <div class="bs_review_section_body is-open">
                                                <div class="bs_review_row">
                                                    <span class="bs_review_k">เลขที่จอง</span>
                                                    <span class="bs_review_v" t-esc="booking.name"/>
                                                </div>
                                                <div class="bs_review_row">
                                                    <span class="bs_review_k">รุ่นรถ</span>
                                                    <span class="bs_review_v"><t t-esc="booking.model_id.brand_id.name"/> <t t-esc="booking.model_id.name"/><t t-if="ext_color"> — <t t-esc="ext_color"/></t></span>
                                                </div>
                                                <div t-if="int_color" class="bs_review_row">
                                                    <span class="bs_review_k">สีภายใน</span>
                                                    <span class="bs_review_v" t-esc="int_color"/>
                                                </div>
                                                <div t-if="booking.model_id.model_year" class="bs_review_row">
                                                    <span class="bs_review_k">ปีที่ผลิต</span>
                                                    <span class="bs_review_v" t-esc="booking.model_id.model_year"/>
                                                </div>
                                                <div t-if="booking.dealer_id" class="bs_review_row">
                                                    <span class="bs_review_k">ผู้แทนจำหน่าย</span>
                                                    <span class="bs_review_v" t-esc="booking.dealer_id.name"/>
                                                </div>
                                                <div class="bs_review_row">
                                                    <span class="bs_review_k">วันที่จอง</span>
                                                    <span class="bs_review_v"><span t-field="booking.create_date" t-options="{'widget': 'date'}"/></span>
                                                </div>
                                                <div class="bs_review_row">
                                                    <span class="bs_review_k">เงินจอง</span>
                                                    <span class="bs_review_v bs_review_v_accent"
                                                          t-esc="booking.deposit_amount"
                                                          t-options="{'widget': 'monetary', 'display_currency': booking.currency_id}"/>
                                                </div>
                                                <div class="bs_review_row">
                                                    <span class="bs_review_k">วันครบกำหนดชำระ</span>
                                                    <span class="bs_review_v bs_review_v_due" t-esc="booking._review_payment_due_thai()"/>
                                                </div>
                                                <div class="bs_review_row">
                                                    <span class="bs_review_k">กำหนดส่งมอบรถ</span>
                                                    <span class="bs_review_v">
                                                        ประมาณ 60 วัน นับจากวันที่ชำระเงิน
                                                    </span>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- 2. ข้อมูลลูกค้า (filled live from the form) -->
                                        <div class="bs_review_section">
                                            <div class="bs_review_section_head" data-review-toggle="">
                                                <span><i class="fa fa-user-o"/>ข้อมูลลูกค้า</span>
                                                <i class="fa fa-chevron-down bs_review_chevron"/>
                                            </div>
                                            <div class="bs_review_section_body is-open" data-review-customer=""/>
                                        </div>

                                        <!-- 3. ของแถมที่ได้รับ (static promotional list) -->
                                        <div class="bs_review_section">
                                            <div class="bs_review_section_head" data-review-toggle="">
                                                <span><i class="fa fa-gift bs_review_gifticon"/>ของแถมที่ได้รับ
                                                    <span class="bs_review_badge bs_review_badge_gift"><i class="fa fa-cube"/> 9 รายการ</span></span>
                                                <i class="fa fa-chevron-down bs_review_chevron"/>
                                            </div>
                                            <div class="bs_review_section_body is-open">
                                                <ul class="bs_review_gifts">
                                                    <li><i class="fa fa-plug"/><span>เครื่องชาร์จติดบ้าน (Home Wallbox)</span></li>
                                                    <li><i class="fa fa-bolt"/><span>สายชาร์จฉุกเฉิน <span class="bs_review_muted">(Type 2 / CCS2)</span></span></li>
                                                    <li><i class="fa fa-money"/><span>เครดิตชาร์จไฟฟรี <span class="bs_review_muted">(สถานีชาร์จสาธารณะ)</span></span></li>
                                                    <li><i class="fa fa-shield"/><span>ประกันภัยชั้น 1 + พ.ร.บ.</span></li>
                                                    <li><i class="fa fa-battery-half"/><span>รับประกันแบตเตอรี่ <span class="bs_review_muted">(8 ปี หรือ 160,000 กม.)</span></span></li>
                                                    <li><i class="fa fa-wrench"/><span>รับประกันตัวรถ + ฟรีค่าบำรุงรักษาตามระยะ <span class="bs_review_muted">(5 ปี หรือ 120,000 กม.)</span></span></li>
                                                    <li><i class="fa fa-ambulance"/><span>บริการช่วยเหลือฉุกเฉิน 24 ชั่วโมง</span></li>
                                                    <li><i class="fa fa-picture-o"/><span>ฟิล์มกรองแสง</span></li>
                                                    <li><i class="fa fa-star"/><span>พรม/ผ้ายางปูพื้น · กรอบป้ายทะเบียน · ของที่ระลึกแบรนด์</span></li>
                                                </ul>
                                                <p class="bs_review_gift_note">* ของแถมอาจเปลี่ยนแปลงตามเงื่อนไขโปรโมชันของบริษัท กรุณาตรวจสอบรายละเอียดในใบจองอีกครั้ง</p>
                                            </div>
                                        </div>

                                        <!-- 4. เอกสารแนบ (built from the selected files) -->
                                        <div class="bs_review_section">
                                            <div class="bs_review_section_head" data-review-toggle="">
                                                <span><i class="fa fa-files-o"/>เอกสารแนบ</span>
                                                <i class="fa fa-chevron-down bs_review_chevron"/>
                                            </div>
                                            <div class="bs_review_section_body is-open">
                                                <div data-review-docs=""/>
                                                <p class="text-muted small mb-0 d-none" data-review-nodocs="">ไม่มีเอกสารแนบ</p>
                                            </div>
                                        </div>

                                        <!-- ยืนยัน -->
                                        <label class="bs_review_check">
                                            <input type="checkbox" data-review-confirm=""/>
                                            <span>ข้าพเจ้าได้ตรวจสอบข้อมูลการจอง ข้อมูลส่วนบุคคล และเอกสารแนบทั้งหมดแล้ว และยืนยันว่าถูกต้องครบถ้วน</span>
                                        </label>
                                        <div class="alert alert-danger mx-3 mb-3 d-none" data-review-error=""/>
                                    </div>

                                    <!-- แถบสถานะ -->
                                    <div class="bs_review_status d-none" data-review-status="">
                                        <i class="fa fa-check-circle"/>
                                        <span>ยืนยันข้อมูลเรียบร้อย — กด <strong>ยืนยันและชำระเงินจอง</strong> เพื่อดำเนินการต่อ</span>
                                    </div>

                                    <div class="bs_review_footer">
                                        <button type="button" class="btn btn-outline-secondary" data-review-edit="">
                                            <i class="fa fa-arrow-left me-1"/> แก้ไขข้อมูล
                                        </button>
                                        <button type="button" class="btn btn-primary" data-review-proceed="" disabled="disabled">
                                            <i class="fa fa-credit-card me-1"/> ยืนยันและชำระเงินจอง
                                        </button>
                                    </div>
                                </div>

                                <!-- Document preview overlay (image / PDF via in-browser file) -->
                                <div class="bs_review_preview d-none" data-review-preview="">
                                    <div class="bs_review_preview_modal">
                                        <div class="bs_review_preview_head">
                                            <span class="bs_review_preview_title" data-review-preview-title=""/>
                                            <button type="button" class="btn btn-sm btn-light" data-review-preview-close="">
                                                <i class="fa fa-times"/> ปิด
                                            </button>
                                        </div>
                                        <div class="bs_review_preview_body" data-review-preview-body=""/>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </section>
        </t>
    </template>

    <!-- ================================================================
         DEPOSIT PAYMENT PAGE  (Step 4) — native payment.form
         ================================================================ -->
    <template id="deposit_payment_page" name="Deposit Payment">
        <t t-call="website.layout">
            <t t-set="title">Pay Deposit</t>
            <section class="payment_section">
                <div class="container">
                    <div class="payment_card">
                        <t t-call="bs_car_booking.booking_progress">
                            <t t-set="active_step" t-value="4"/>
                        </t>
                        <div class="payment_header text-center">
                            <i class="fa fa-lock fa-2x text-success"/>
                            <h2>Secure Deposit · 2C2P</h2>
                            <p>
                                Booking <strong t-esc="booking.name"/> —
                                <t t-esc="booking.model_id.name"/>
                            </p>
                        </div>
                        <div class="payment_amount">
                            <span class="payment_label">Deposit to reserve</span>
                            <span class="payment_value" t-esc="deposit_amount"
                                  t-options="{'widget': 'monetary', 'display_currency': booking.currency_id}"/>
                            <div class="text-muted mt-1">
                                Order total:
                                <span t-esc="booking.amount_total"
                                      t-options="{'widget': 'monetary', 'display_currency': booking.currency_id}"/>
                            </div>
                        </div>
                        <div class="payment_form_wrap">
                            <t t-call="payment.form"/>
                        </div>
                    </div>
                </div>
            </section>
        </t>
    </template>

    <!-- ================================================================
         CONFIRMATION PAGE  (Step 5)
         ================================================================ -->
    <template id="booking_confirmation_page" name="Booking Confirmation">
        <t t-call="website.layout">
            <t t-set="title">Booking Confirmed!</t>
            <t t-set="is_confirmed"
               t-value="booking.state in ('confirmed', 'in_production', 'ready_delivery', 'delivered')"/>
            <t t-set="is_closed" t-value="booking.state in ('cancelled', 'expired')"/>
            <section class="confirmation_section">
                <div class="container">
                    <div class="confirmation_card text-center">
                        <t t-if="not is_closed" t-call="bs_car_booking.booking_progress">
                            <t t-set="active_step" t-value="is_confirmed and 5 or 4"/>
                        </t>
                        <div class="confirmation_icon">
                            <i t-if="is_confirmed" class="fa fa-check-circle fa-4x text-success"/>
                            <i t-elif="booking.state == 'cancelled'" class="fa fa-times-circle fa-4x text-danger"/>
                            <i t-elif="booking.state == 'expired'" class="fa fa-hourglass-end fa-4x text-muted"/>
                            <i t-else="" class="fa fa-clock-o fa-4x text-warning"/>
                        </div>
                        <h2>
                            <t t-if="is_confirmed">Booking Confirmed!</t>
                            <t t-elif="booking.state == 'cancelled'">Booking Cancelled</t>
                            <t t-elif="booking.state == 'expired'">Booking Expired</t>
                            <t t-else="">Booking In Progress</t>
                        </h2>
                        <div class="confirmation_status">
                            <span t-attf-class="badge car_status_badge {{ is_confirmed and 'bg-success' or booking.state == 'cancelled' and 'bg-danger' or booking.state == 'expired' and 'bg-secondary' or 'bg-warning text-dark' }}">
                                <t t-esc="booking.state_label"/>
                            </span>
                        </div>

                        <div class="confirmation_details">
                            <div class="conf_row">
                                <span class="conf_label">Booking Ref</span>
                                <span class="conf_value" t-esc="booking.name"/>
                            </div>
                            <div class="conf_row">
                                <span class="conf_label">Car</span>
                                <span class="conf_value">
                                    <t t-esc="booking.model_id.brand_id.name"/> <t t-esc="booking.model_id.name"/>
                                </span>
                            </div>
                            <div class="conf_row" t-if="booking.config_summary">
                                <span class="conf_label">Configuration</span>
                                <span class="conf_value" t-esc="booking.config_summary"/>
                            </div>
                            <div class="conf_row" t-if="booking.dealer_id">
                                <span class="conf_label">Dealer</span>
                                <span class="conf_value" t-esc="booking.dealer_id.name"/>
                            </div>
                            <div class="conf_row" t-if="booking.sale_order_id">
                                <span class="conf_label">Sale Order</span>
                                <span class="conf_value" t-esc="booking.sale_order_id.name"/>
                            </div>
                            <div class="conf_row">
                                <span class="conf_label">Order Total</span>
                                <span class="conf_value" t-esc="booking.amount_total"
                                      t-options="{'widget': 'monetary', 'display_currency': booking.currency_id}"/>
                            </div>
                            <div class="conf_row" t-if="booking.estimated_delivery_date">
                                <span class="conf_label">Est. Delivery</span>
                                <span class="conf_value" t-field="booking.estimated_delivery_date"/>
                            </div>
                            <div class="conf_row">
                                <span class="conf_label">Deposit Paid</span>
                                <span class="conf_value" t-esc="booking.deposit_paid"
                                      t-options="{'widget': 'monetary', 'display_currency': booking.currency_id}"/>
                            </div>
                        </div>

                        <div t-if="booking.invoice_ids" class="confirmation_invoices">
                            <h5>Deposit Invoice<t t-if="len(booking.invoice_ids) &gt; 1">s</t></h5>
                            <t t-foreach="booking.invoice_ids" t-as="inv">
                                <div class="conf_invoice_row">
                                    <span t-esc="inv.name"/>
                                    <span t-esc="inv.amount_total"
                                          t-options="{'widget': 'monetary', 'display_currency': inv.currency_id}"/>
                                    <span class="badge bg-light text-dark" t-esc="inv.payment_state"/>
                                </div>
                            </t>
                        </div>

                        <div class="confirmation_actions py-4">
                            <a href="/cars" class="btn btn-outline-primary">
                                <i class="fa fa-arrow-left"/> Browse More Cars
                            </a>
                            <a t-if="not is_confirmed and not is_closed"
                               t-att-href="'/booking/%s/payment?access_token=%s' % (booking.id, access_token)"
                               class="btn btn-success ms-2">
                                <i class="fa fa-credit-card"/> Pay Deposit
                            </a>
                            <a t-att-href="booking.get_portal_url()" class="btn btn-primary ms-2">
                                <i class="fa fa-user"/> View in My Account
                            </a>
                        </div>

                        <!-- ── Customer Rating ── -->
                        <t t-if="is_confirmed">
                            <hr class="conf_divider"/>
                            <!-- Already rated: show thank-you -->
                            <div t-if="booking.rating" class="conf_rating_done text-center py-3">
                                <div class="conf_rating_stars">
                                    <t t-foreach="range(1, 6)" t-as="i">
                                        <i t-attf-class="fa fa-star{{ ' conf_star_lit' if i &lt;= booking.rating else '-o' }}"/>
                                    </t>
                                </div>
                                <p class="conf_rating_thanks mt-2">Thank you for your rating!</p>
                                <p class="text-muted small"><t t-esc="booking.rating"/>/5
                                    <t t-if="booking.rating_comment"> — <t t-esc="booking.rating_comment"/></t>
                                </p>
                            </div>
                            <!-- Not yet rated: show form -->
                            <div t-else=""
                                 class="conf_rating_block"
                                 t-att-data-booking-id="booking.id"
                                 t-att-data-access-token="access_token">
                                <p class="conf_rating_title">Rate your booking experience</p>
                                <p class="text-muted small mb-2">Customer Rating (1–5 Stars)</p>
                                <div class="conf_stars" id="conf_stars">
                                    <span class="conf_star" data-value="1">&#9733;</span>
                                    <span class="conf_star" data-value="2">&#9733;</span>
                                    <span class="conf_star" data-value="3">&#9733;</span>
                                    <span class="conf_star" data-value="4">&#9733;</span>
                                    <span class="conf_star" data-value="5">&#9733;</span>
                                </div>
                                <div class="conf_rating_desc" id="conf_rating_desc">Please give a rating</div>
                                <textarea id="conf_rating_comment" class="form-control form-control-sm conf_rating_comment mt-2"
                                          rows="2" placeholder="Additional comments (optional)"/>
                                <button id="conf_rating_submit" class="conf_rating_submit_btn btn btn-warning mt-2" disabled="disabled">
                                    <i class="fa fa-paper-plane"/> Submit Rating
                                </button>
                                <button id="conf_rating_skip" class="conf_rating_skip_btn btn btn-link btn-sm mt-1 d-block mx-auto">
                                    Skip for now
                                </button>
                                <div id="conf_rating_error" class="alert alert-danger mt-2 d-none"/>
                            </div>
                        </t>
                    </div>
                </div>
            </section>
        </t>
    </template>
</odoo>
