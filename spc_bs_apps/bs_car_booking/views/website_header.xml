<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         BRAND HEADER — mirrors the Hongqi Thailand marketing site:
         a centered logo + a minimal, letter-spaced nav, with none of the
         default e-commerce extras (cart, search, phone, CTA). Account +
         language are kept so customers still reach /my and switch EN/ไทย.

         ROBUST STRATEGY — replace the WHOLE <header>, not just //header//nav.
         A "selectable header" that replaces //header//nav is the textbook
         pattern, BUT it is FRAGILE in production: if any other active view (a
         website-specific COW copy of a header template created by the builder,
         or a website_sale header variant) has already replaced //header//nav,
         that node no longer exists when our xpath runs and rendering dies with
             "Element '//header//nav' cannot be located in parent view".
         This is environment-dependent (a clean dev DB never sees it; a live,
         builder-edited / website_sale DB does), so we DO NOT rely on it.

         Instead we REPLACE THE ENTIRE <header> at the highest priority:
           * //header ALWAYS exists (from web.frontend_layout) -> the xpath can
             never fail to locate its target, on any website / COW state;
           * priority 999 means we run LAST, after every other header view has
             finished editing the original nav, which we simply discard.
         We re-add the classes the scroll/affix interactions need
         (header#top + o_header_standard, see header_standard.js) so the
         transparent-overlay -> solid-on-scroll behaviour keeps working.
         ================================================================ -->

    <template id="template_header_hongqi" inherit_id="website.layout"
              name="Hongqi Brand Header" priority="999">
        <!-- Header overlays the page ONLY where a full-bleed hero opts in via
             `bs_hero_overlay` (set in those page templates). Other pages
             (compare, funnel, ...) keep the normal solid header (no overlap). -->
        <xpath expr="//div[@id='wrapwrap']" position="attributes">
            <attribute name="t-attf-class" add="#{'o_header_overlay' if bs_hero_overlay else ''}" separator=" "/>
        </xpath>

        <!-- Authoritative brand header: overrides whatever header the website
             would otherwise render (crash-proof regardless of COW state). -->
        <xpath expr="//header" position="replace">
            <header id="top" data-anchor="true" data-name="Header"
                    class="o_header_standard bs_brand_header">
                <t t-call="website.navbar">
                    <t t-set="_navbar_classes" t-valuef="d-none d-lg-block"/>
                    <div id="o_main_nav" t-attf-class="o_main_nav #{header_content_width or 'container'} bs_brand_nav">
                        <!-- Left spacer mirrors the account block so the centred
                             logo+nav stays centred (3-zone flex, no overlap). -->
                        <span class="bs_brand_spacer" aria-hidden="true"/>
                        <!-- Centred group: brand logo + minimal menu -->
                        <div class="bs_brand_center">
                            <t t-call="website.placeholder_header_brand" _link_class.f="bs_brand_logo"/>
                            <t t-call="website.navbar_nav" _nav_class.f="bs_brand_links">
                                <t t-foreach="website.menu_id.child_id" t-as="submenu">
                                    <t t-call="website.submenu"
                                       item_class.f="nav-item" link_class.f="nav-link"/>
                                </t>
                            </t>
                        </div>
                        <!-- Account: Sign in (logged out) / My Account dropdown
                             with booking history (logged in) + language selector. -->
                        <ul class="navbar-nav bs_brand_account">
                            <!-- Language selector (EN / ไทย) - only when >1 lang active. -->
                            <t t-call="website.placeholder_header_language_selector">
                                <t t-set="_btn_class" t-valuef="nav-link"/>
                                <t t-set="_dropdown_menu_class" t-valuef="dropdown-menu-end"/>
                            </t>
                            <t t-call="portal.placeholder_user_sign_in">
                                <t t-set="_link_class" t-valuef="nav-link bs_brand_signin"/>
                            </t>
                            <t t-call="portal.user_dropdown">
                                <t t-set="_user_name" t-value="True"/>
                                <t t-set="_item_class" t-valuef="dropdown"/>
                                <t t-set="_link_class" t-valuef="nav-link"/>
                                <t t-set="_dropdown_menu_class" t-valuef="dropdown-menu-end"/>
                            </t>
                        </ul>
                    </div>
                </t>
                <t t-call="website.template_header_mobile"/>
            </header>
        </xpath>
    </template>
</odoo>
