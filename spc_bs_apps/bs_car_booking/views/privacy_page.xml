<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Privacy / PDPA page (the consent checkbox links here).
         Content is editable in the website builder; this is the default. -->
    <record id="privacy_policy_view" model="ir.ui.view">
        <field name="name">Privacy Policy (PDPA)</field>
        <field name="type">qweb</field>
        <field name="key">bs_car_booking.privacy_policy</field>
        <field name="arch" type="xml">
            <t t-name="bs_car_booking.privacy_policy">
                <t t-call="website.layout">
                    <t t-set="title">Privacy Policy</t>
                    <div id="wrap" class="oe_structure">
                        <section class="s_text_block container py-5">
                            <div class="row"><div class="col-lg-9 mx-auto">
                                <h1>Privacy Policy (PDPA)</h1>
                                <p class="text-muted">Last updated on booking submission.</p>
                                <p>We collect and process your personal data — including your name,
                                   mobile number, email and the vehicle configuration you select — in
                                   order to verify your identity (via mobile OTP), prepare your booking
                                   and deposit, and contact you about your reservation.</p>
                                <h3>What we collect</h3>
                                <ul>
                                    <li>Contact details: name, mobile number, email, address.</li>
                                    <li>Booking details: selected model, configuration and preferred dealer.</li>
                                    <li>Consent record: date and time you accepted this policy.</li>
                                </ul>
                                <h3>How we use it</h3>
                                <ul>
                                    <li>To send a one-time verification code (OTP) to your mobile.</li>
                                    <li>To create and manage your booking, deposit invoice and payment.</li>
                                    <li>To contact you (phone/SMS/email) about your booking and related offers.</li>
                                </ul>
                                <h3>Your rights</h3>
                                <p>You may withdraw consent, or request access, correction or deletion of
                                   your personal data at any time by contacting our dealership. We retain
                                   your data only as long as necessary for the booking and legal obligations.</p>
                                <p><em>Please replace this template with your organisation's official PDPA
                                   privacy notice.</em></p>
                            </div></div>
                        </section>
                    </div>
                </t>
            </t>
        </field>
    </record>

    <record id="privacy_policy_page" model="website.page">
        <field name="name">Privacy Policy</field>
        <field name="view_id" ref="privacy_policy_view"/>
        <field name="url">/privacy</field>
        <field name="is_published">True</field>
    </record>
</odoo>
