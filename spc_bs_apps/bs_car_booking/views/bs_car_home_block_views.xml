<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bs_car_home_block_list" model="ir.ui.view">
        <field name="name">bs.car.home.block.list</field>
        <field name="model">bs.car.home.block</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="block_type"/>
                <field name="model_id"
                       options="{'no_create': True}"
                       placeholder="(uses Featured on Home)"/>
                <field name="name" optional="hide"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_bs_car_home_block_form" model="ir.ui.view">
        <field name="name">bs.car.home.block.form</field>
        <field name="model">bs.car.home.block</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="block_type"/>
                        <field name="model_id" options="{'no_create': True}"
                               placeholder="(uses the model flagged Featured on Home)"
                               invisible="block_type in ('lineup', 'dealers', 'offers', 'arrivals', 'stats', 'heritage', 'browse')"/>
                        <field name="sequence"/>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                    <div class="text-muted">
                        The <b>/showroom</b> page renders these sections in order. Leave
                        <b>Car Model</b> empty to use the model flagged “Featured on Home”.
                        Model stage, colour studio, highlights and cabin story are driven by
                        <b>Showcase Items</b>. Leave <b>Latest Stories</b> empty for brand-wide stories,
                        or select a model to show model-specific stories. The <b>Lineup</b> section
                        always lists all published models.
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_bs_car_home_block" model="ir.actions.act_window">
        <field name="name">Home Layout</field>
        <field name="res_model">bs.car.home.block</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Build your home page from the back office</p>
            <p>Add ordered sections (hero, stage, colour studio, specs, highlights, stories) — each can target its own car model.</p>
        </field>
    </record>

    <menuitem id="menu_bs_car_home_block"
              name="Home Layout"
              parent="menu_bs_car_booking_master"
              action="action_bs_car_home_block"
              sequence="50"/>
</odoo>
