<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Public "Track my booking" page: reference + phone -> one-time code ->
         hand off to the token-gated status view. No login required. -->
    <template id="tracking_page" name="My Booking">
        <t t-call="website.layout">
            <t t-set="title">My booking</t>
            <t t-set="bs_hero_overlay" t-value="True"/>
            <div id="wrap" class="bs_track_shell">
                <section class="bs_track_hero">
                    <div class="container">
                        <span class="car_kicker">Booking Status</span>
                        <h1 class="bs_track_title">My booking</h1>
                        <p class="bs_track_sub">
                            Enter your booking reference and the phone number you used.
                            <t t-if="otp_mode == 'email'">
                                We will email you a one-time code to confirm it is you.
                            </t>
                            <t t-elif="otp_mode == 'sms'">
                                We will text you a one-time code to confirm it is you.
                            </t>
                            <t t-else="">
                                We will send a one-time code to confirm it is you.
                            </t>
                        </p>
                    </div>
                </section>
                <section class="bs_track_body">
                    <div class="container">
                        <div class="bs_track_card" id="bs_track">
                            <!-- Step 1: reference + phone -->
                            <div class="bs_track_step" data-track-step="lookup">
                                <div class="mb-3">
                                    <label class="bs_track_label">Booking reference</label>
                                    <input type="text" class="form-control bs_track_input"
                                           data-track-ref="1" placeholder="e.g. CBK/2026/06/00042"
                                           autocomplete="off"/>
                                </div>
                                <div class="mb-3">
                                    <label class="bs_track_label">Phone number</label>
                                    <input type="tel" class="form-control bs_track_input"
                                           data-track-phone="1" placeholder="+66 8 1234 5678"
                                           pattern="^\+?[0-9\s\-]{7,15}$"
                                           autocomplete="off"/>
                                    <small class="text-muted">
                                        Use the same number you entered when booking.
                                    </small>
                                </div>
                                <button type="button" class="btn btn-primary car_cta_btn w-100"
                                        data-track-send="1">
                                    Send code <i class="fa fa-arrow-right"/>
                                </button>
                            </div>
                            <!-- Step 2: OTP -->
                            <div class="bs_track_step d-none" data-track-step="otp">
                                <!-- The hint follows the WEBSITE delivery mode (same for
                                     every visitor), so it names the channel without
                                     leaking anything about a specific booking. -->
                                <p class="bs_track_otp_hint">
                                    <t t-if="otp_mode == 'email'">
                                        Enter the 6-digit code from your email.
                                        Check your inbox and spam folder.
                                    </t>
                                    <t t-elif="otp_mode == 'sms'">
                                        Enter the 6-digit code we sent to your phone by SMS.
                                    </t>
                                    <t t-else="">
                                        Enter the 6-digit code we just sent you.
                                        Check your SMS and email inbox (including spam).
                                    </t>
                                </p>
                                <!-- Same 6-box code entry as the funnel verify page. -->
                                <div class="otp_input_group bs_track_digits">
                                    <t t-foreach="range(6)" t-as="i">
                                        <input type="text" class="otp_digit" maxlength="1"
                                               t-att-data-index="i" inputmode="numeric" pattern="[0-9]"
                                               t-att-autocomplete="i == 0 and 'one-time-code' or 'off'"/>
                                    </t>
                                </div>
                                <div class="bs_track_timer_row" data-track-timer-row="">
                                    <button type="button" class="bs_track_resend_btn"
                                            data-track-resend="1" disabled="">
                                        <i class="fa fa-refresh"/>
                                        <span data-track-resend-label="">Resend code</span>
                                    </button>
                                </div>
                                <button type="button" class="btn btn-primary car_cta_btn w-100 mt-3"
                                        data-track-verify="1">
                                    View my booking <i class="fa fa-arrow-right"/>
                                </button>
                            </div>
                            <!-- Feedback -->
                            <div class="bs_track_msg d-none" data-track-msg="1" role="status"/>
                        </div>
                        <p class="bs_track_help">
                            Already have an account?
                            <a href="/my/bookings">Track from My Account</a>.
                        </p>
                    </div>
                </section>
            </div>
        </t>
    </template>
</odoo>
