<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         REUSABLE BOOKING PROGRESS STEPPER
         Pass `active_step` (1=Configure, 2=Verify, 3=Info, 4=Deposit, 5=Done)
         ================================================================ -->
    <template id="booking_progress" name="Booking Progress">
        <div class="booking_progress">
            <t t-set="steps" t-value="[(1, 'Configure', 'fa-sliders'), (2, 'Verify', 'fa-shield'), (3, 'Details', 'fa-user'), (4, 'Deposit', 'fa-credit-card'), (5, 'Done', 'fa-check')]"/>
            <t t-foreach="steps" t-as="step">
                <div t-attf-class="bp_step {{ active_step &gt; step[0] and 'is-done' or '' }} {{ active_step == step[0] and 'is-active' or '' }}">
                    <span class="bp_dot">
                        <i t-if="active_step &gt; step[0]" class="fa fa-check"/>
                        <i t-else="" t-attf-class="fa {{ step[2] }}"/>
                    </span>
                    <span class="bp_label" t-esc="step[1]"/>
                </div>
            </t>
        </div>
    </template>

    <!-- ================================================================
         CONFIGURATOR PAGE  (Step 1)
         Configure attributes + pick dealer + phone → create booking
         ================================================================ -->
    <template id="booking_configurator_page" name="Configure Your Car">
        <t t-call="website.layout">
            <t t-set="title">Configure your <t t-esc="car.name"/></t>

            <section class="cfg_hero">
                <t t-if="car.image">
                    <img t-att-src="'/web/image/bs.car.model/%s/image' % car.id"
                         t-att-alt="car.name" class="cfg_hero_img"/>
                </t>
                <div t-else="" class="cfg_hero_img cfg_hero_fallback"/>
                <div class="cfg_hero_overlay">
                    <div class="container cfg_hero_content" data-bs-car-reveal="hero">
                        <span class="cfg_brand" t-esc="car.brand_id.name"/>
                        <h1 class="cfg_title" t-esc="car.name"/>
                        <p>
                            Build the exact color, interior, wheel, and add-on combination
                            before choosing your preferred dealer.
                        </p>
                    </div>
                </div>
            </section>

            <section class="container py-4">
                <t t-call="bs_car_booking.booking_progress">
                    <t t-set="active_step" t-value="1"/>
                </t>
            </section>

            <section class="container cfg_wrapper pb-6">
                <div t-if="product_missing" class="alert alert-warning">
                    This model is not ready for online booking yet. Ask a booking manager to generate the configurable product in the back office.
                </div>
                <form id="bs_configurator_form" class="cfg_form"
                      t-att-data-model-id="car.id"
                      t-att-data-deposit="car.deposit_amount"
                      t-att-data-currency-id="car.currency_id.id"
                      t-att-data-product-missing="product_missing and '1' or '0'">

                    <div class="cfg_grid">
                        <div class="cfg_options">
                            <div class="cfg_intro" data-bs-car-reveal="up">
                                <span class="car_kicker car_kicker_dark">Configuration</span>
                                <h2>Make it yours.</h2>
                                <p>
                                    Pricing updates live from the generated Odoo product variant and
                                    no-variant option values.
                                </p>
                            </div>

                            <t t-set="config_block_index" t-value="0"/>
                            <t t-foreach="attribute_lines" t-as="line">
                                <t t-set="is_single_standard_package"
                                   t-value="standard_package_attr and line.attribute_id == standard_package_attr and len(line.product_template_value_ids) == 1"/>
                                <t t-if="is_single_standard_package">
                                    <t t-set="standard_ptav" t-value="line.product_template_value_ids[:1]"/>
                                    <input type="radio" class="cfg_input d-none"
                                           t-attf-name="attr_{{ line.attribute_id.id }}"
                                           t-att-data-ptav-id="standard_ptav.id"
                                           t-att-data-price-extra="standard_ptav.price_extra"
                                           t-att-data-summary-label="standard_ptav.name"
                                           data-summary-hidden="1"
                                           checked="checked"/>
                                </t>
                                <div t-else="" class="cfg_block" t-att-data-attribute-id="line.attribute_id.id"
                                     data-bs-car-reveal="up">
                                    <t t-set="config_block_index" t-value="config_block_index + 1"/>
                                    <div class="cfg_block_heading">
                                        <span class="cfg_block_number" t-esc="config_block_index"/>
                                        <h4 class="cfg_block_title" t-esc="line.attribute_id.name"/>
                                    </div>

                                    <t t-if="line.attribute_id.display_type == 'color'">
                                        <div class="cfg_swatches">
                                            <t t-foreach="line.product_template_value_ids" t-as="ptav">
                                                <label class="cfg_swatch" t-att-title="ptav.name">
                                                    <input type="radio" class="cfg_input d-none"
                                                           t-attf-name="attr_{{ line.attribute_id.id }}"
                                                           t-att-data-ptav-id="ptav.id"
                                                           t-att-data-price-extra="ptav.price_extra"
                                                           t-att-data-summary-label="ptav.name"
                                                           t-att-checked="ptav_first and 'checked' or None"/>
                                                    <span class="cfg_swatch_dot"
                                                          t-attf-style="background-color: {{ ptav.product_attribute_value_id.html_color or '#888' }}"/>
                                                    <span class="cfg_swatch_name" t-esc="ptav.name"/>
                                                </label>
                                            </t>
                                        </div>
                                    </t>

                                    <t t-elif="line.attribute_id.display_type == 'multi'">
                                        <div class="cfg_addons">
                                            <t t-foreach="line.product_template_value_ids" t-as="ptav">
                                                <label class="cfg_addon">
                                                    <input type="checkbox" class="cfg_input"
                                                           t-att-data-ptav-id="ptav.id"
                                                           t-att-data-price-extra="ptav.price_extra"
                                                           t-att-data-summary-label="ptav.name"/>
                                                    <span class="cfg_addon_name" t-esc="ptav.name"/>
                                                    <span class="cfg_addon_price"
                                                          t-if="ptav.price_extra"
                                                          t-esc="ptav.price_extra"
                                                          t-options="{'widget': 'monetary', 'display_currency': car.currency_id}"/>
                                                </label>
                                            </t>
                                        </div>
                                    </t>

                                    <t t-else="">
                                        <div class="cfg_pills">
                                            <t t-foreach="line.product_template_value_ids" t-as="ptav">
                                                <label class="cfg_pill">
                                                    <input type="radio" class="cfg_input d-none"
                                                           t-attf-name="attr_{{ line.attribute_id.id }}"
                                                           t-att-data-ptav-id="ptav.id"
                                                           t-att-data-price-extra="ptav.price_extra"
                                                           t-att-data-summary-label="ptav.name"
                                                           t-att-checked="ptav_first and 'checked' or None"/>
                                                    <span class="cfg_pill_name" t-esc="ptav.name"/>
                                                    <span class="cfg_pill_price"
                                                          t-if="ptav.price_extra"
                                                          t-esc="ptav.price_extra"
                                                          t-options="{'widget': 'monetary', 'display_currency': car.currency_id}"/>
                                                </label>
                                            </t>
                                        </div>
                                    </t>
                                </div>
                            </t>

                            <div class="cfg_block" data-bs-car-reveal="up">
                                <div class="cfg_block_heading">
                                    <span class="cfg_block_number">D</span>
                                    <h4 class="cfg_block_title">Preferred Dealer</h4>
                                </div>
                                <div class="dealer_select_grid">
                                    <t t-foreach="dealers" t-as="dealer">
                                        <label class="dealer_select_card">
                                            <input type="radio" name="dealer_id" class="d-none"
                                                   t-att-value="dealer.id"
                                                   t-att-checked="dealer_first and 'checked' or None"/>
                                            <img t-if="dealer.image"
                                                 t-att-src="'/web/image/bs.car.dealer/%s/image/400x260' % dealer.id"
                                                 t-att-alt="dealer.name"/>
                                            <div class="dealer_card_content">
                                                <h6 t-esc="dealer.name"/>
                                                <small t-if="dealer.city" t-esc="dealer.city"/>
                                            </div>
                                        </label>
                                    </t>
                                </div>
                            </div>

                            <div class="cfg_block" data-bs-car-reveal="up">
                                <div class="cfg_block_heading">
                                    <span class="cfg_block_number">V</span>
                                    <h4 class="cfg_block_title">Mobile Number</h4>
                                </div>
                                <div class="cfg_phone_row">
                                    <input type="tel" id="cfg_phone" class="form-control form-control-lg"
                                           placeholder="+66 8 1234 5678" required="required"
                                           pattern="^\+?[0-9\s\-]{7,15}$"/>
                                    <small class="text-muted">We'll send a verification code to this number.</small>
                                </div>
                            </div>
                        </div>

                        <aside class="cfg_summary">
                            <div class="cfg_summary_card" data-bs-car-reveal="up">
                                <div class="cfg_summary_media">
                                    <t t-if="car.image">
                                        <img t-att-src="'/web/image/bs.car.model/%s/image/480x300' % car.id"
                                             t-att-alt="car.name"/>
                                    </t>
                                </div>
                                <div class="cfg_summary_body">
                                    <span class="car_kicker car_kicker_dark" t-esc="car.brand_id.name"/>
                                    <h5 t-esc="car.name"/>
                                    <div class="cfg_selected_list" id="cfg_selected_list"/>
                                    <div class="cfg_price_label">Estimated price</div>
                                    <div class="cfg_price" id="cfg_price"
                                         t-esc="base_price"
                                         t-options="{'widget': 'monetary', 'display_currency': car.currency_id}"/>
                                    <div class="cfg_deposit">
                                        Deposit to reserve:
                                        <strong t-esc="car.deposit_amount"
                                                t-options="{'widget': 'monetary', 'display_currency': car.currency_id}"/>
                                    </div>
                                    <label class="cfg_pdpa">
                                        <input type="checkbox" id="cfg_pdpa" class="cfg_pdpa_check"/>
                                        <span>I agree to the
                                            <a href="/privacy" target="_blank" rel="noopener">Privacy Policy (PDPA)</a>
                                            and consent to being contacted about this booking.</span>
                                    </label>
                                    <button type="submit" class="btn btn-primary btn-lg cfg_submit_btn"
                                            t-att-disabled="product_missing and 'disabled' or None">
                                        <i class="fa fa-shield"/> Continue to Verify
                                    </button>
                                    <div class="cfg_error alert alert-danger mt-3 d-none" id="cfg_error"/>
                                </div>
                            </div>
                        </aside>
                    </div>
                </form>
            </section>
        </t>
    </template>
</odoo>
