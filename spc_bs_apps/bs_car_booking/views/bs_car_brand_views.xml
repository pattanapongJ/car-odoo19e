<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Car Brand Form & Tree -->
    <record id="view_bs_car_brand_tree" model="ir.ui.view">
        <field name="name">bs.car.brand.tree</field>
        <field name="model">bs.car.brand</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="model_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_bs_car_brand_form" model="ir.ui.view">
        <field name="name">bs.car.brand.form</field>
        <field name="model">bs.car.brand</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Brand Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="website_featured"/>
                        </group>
                        <group>
                            <field name="logo" widget="image"/>
                        </group>
                    </group>
                    <group string="Website Description">
                        <field name="website_description" widget="html"/>
                    </group>
                    <group string="Heritage (home Brand Heritage section)">
                        <field name="tagline" placeholder="The flag bearer of Chinese luxury"/>
                        <field name="heritage_title" placeholder="A flagship legacy, reimagined"/>
                        <field name="heritage_image" widget="image"/>
                        <field name="heritage_cta_label"/>
                        <field name="heritage_cta_url"/>
                        <field name="heritage_html" widget="html" nolabel="1" colspan="2"/>
                    </group>
                    <group string="Models">
                        <field name="model_ids" context="{'default_brand_id': id}">
                            <list>
                                <field name="name"/>
                                <field name="body_type"/>
                                <field name="base_price"/>
                                <field name="website_published"/>
                                <field name="active"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_bs_car_brand_search" model="ir.ui.view">
        <field name="name">bs.car.brand.search</field>
        <field name="model">bs.car.brand</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter name="active" string="Active" domain="[('active', '=', True)]"/>
                <filter name="inactive" string="Inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_bs_car_brand" model="ir.actions.act_window">
        <field name="name">Car Brands</field>
        <field name="res_model">bs.car.brand</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_bs_car_brand_tree"/>
    </record>
</odoo>
